---
import BaseLayout from '@/layouts/BaseLayout.astro';
import { SITE } from '@/config/site';
import { FORMS } from '@/config/forms';

const jsonLd = {
  "@context": "https://schema.org",
  "@type": "WebPage",
  "name": "CSR & Philanthropy | SPVH Group",
  "description": "Fostering positive change through sustainable projects and meaningful partnerships.",
  "url": `${SITE.url}csr-philanthropy`
};
---

<BaseLayout title="CSR & Philanthropy | SPVH Group" description="Our corporate social responsibility initiatives are dedicated to fostering positive change through sustainable projects and meaningful partnerships." jsonLd={jsonLd}>

  <!-- Hero: Full-bleed image, left-aligned content, strong presence -->
  <section class="relative min-h-[85vh] flex items-end pb-20 pt-32 overflow-hidden">
    <div class="absolute inset-0 z-0">
      <img
        src="https://images.pexels.com/photos/6646918/pexels-photo-6646918.jpeg?auto=compress&cs=tinysrgb&w=1920"
        srcset="https://images.pexels.com/photos/6646918/pexels-photo-6646918.jpeg?auto=compress&cs=tinysrgb&w=640 640w, https://images.pexels.com/photos/6646918/pexels-photo-6646918.jpeg?auto=compress&cs=tinysrgb&w=1024 1024w, https://images.pexels.com/photos/6646918/pexels-photo-6646918.jpeg?auto=compress&cs=tinysrgb&w=1920 1920w"
        sizes="100vw"
        alt="Community volunteers working together on a sustainability project"
        class="w-full h-full object-cover"
        fetchpriority="high"
        loading="eager"
      />
      <div class="absolute inset-0 bg-gradient-to-t from-dark via-dark/70 to-dark/30"></div>
    </div>

    <div class="container mx-auto px-4 relative z-10">
      <div class="max-w-3xl hero-animate">
        <p class="text-secondary font-semibold text-sm tracking-widest uppercase mb-4">CSR &amp; Philanthropy</p>
        <h1 class="text-4xl md:text-6xl lg:text-7xl font-bold text-white mb-8 tracking-tight leading-[1.05]">
          Capital with<br/>Conscience
        </h1>
        <p class="text-lg md:text-xl text-white/80 leading-relaxed max-w-2xl">
          We believe in philanthropy that creates lasting, measurable impact. Our initiatives channel resources into education, sustainability, and community health to strengthen the foundations that markets alone cannot build.
        </p>
      </div>
    </div>
  </section>

  <!-- Impact statement: a single bold line to bridge hero and pillars -->
  <section class="py-16 md:py-20 bg-dark border-b border-white/5">
    <div class="container mx-auto px-4">
      <p class="text-2xl md:text-3xl lg:text-4xl text-white/90 font-medium leading-snug max-w-5xl tracking-tight" style="text-wrap: balance;">
        Sustainable change requires patient capital, strategic intent, and deep community trust. We invest in all three.
      </p>
    </div>
  </section>

  <!-- Impact Pillars: asymmetric layout, not identical cards -->
  <section class="py-24 md:py-32 bg-dark relative overflow-hidden">
    <div class="container mx-auto px-4">
      <!-- Pillar 1: Education — full-width featured -->
      <div class="grid grid-cols-1 lg:grid-cols-2 gap-0 mb-2 rounded-2xl overflow-hidden border border-white/10">
        <div class="relative min-h-[320px] lg:min-h-[420px]">
          <img
            src="https://images.pexels.com/photos/8613089/pexels-photo-8613089.jpeg?auto=compress&cs=tinysrgb&w=800"
            alt="Students learning together in a classroom workshop"
            class="w-full h-full object-cover"
            loading="lazy"
          />
        </div>
        <div class="p-10 lg:p-14 flex flex-col justify-center bg-white/[0.03]">
          <div class="flex items-center gap-3 mb-6">
            <div class="w-10 h-10 rounded-lg bg-secondary/20 flex items-center justify-center">
              <svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="var(--color-secondary)" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M2 3h6a4 4 0 0 1 4 4v14a3 3 0 0 0-3-3H2z"/><path d="M22 3h-6a4 4 0 0 0-4 4v14a3 3 0 0 1 3-3h7z"/></svg>
            </div>
            <span class="text-secondary font-semibold text-sm tracking-wide uppercase">Education</span>
          </div>
          <h3 class="text-3xl md:text-4xl font-bold text-white mb-6 tracking-tight leading-tight">Empowering the Next Generation</h3>
          <p class="text-white/60 leading-relaxed text-lg mb-8">
            We fund targeted skill-building programmes and accessibility initiatives that bridge the opportunity gap. Our educational frameworks equip learners with modern, market-relevant competencies, from financial literacy workshops to STEM scholarships in underserved regions.
          </p>
          <div class="flex gap-8">
            <div>
              <p class="text-3xl font-bold text-white">500+</p>
              <p class="text-white/40 text-sm mt-1">Students Supported</p>
            </div>
            <div>
              <p class="text-3xl font-bold text-white">12</p>
              <p class="text-white/40 text-sm mt-1">Active Programmes</p>
            </div>
          </div>
        </div>
      </div>

      <!-- Pillars 2 & 3: side by side, text-driven -->
      <div class="grid grid-cols-1 md:grid-cols-2 gap-2">
        <!-- Sustainability -->
        <div class="rounded-2xl border border-white/10 bg-white/[0.03] overflow-hidden">
          <div class="relative h-56">
            <img
              src="https://images.pexels.com/photos/1072824/pexels-photo-1072824.jpeg?auto=compress&cs=tinysrgb&w=800"
              alt="Solar panels across a green field under clear sky"
              class="w-full h-full object-cover"
              loading="lazy"
            />
            <div class="absolute inset-0 bg-gradient-to-t from-dark/90 to-transparent"></div>
            <div class="absolute bottom-4 left-6 flex items-center gap-3">
              <div class="w-9 h-9 rounded-lg bg-emerald-500/20 flex items-center justify-center">
                <svg xmlns="http://www.w3.org/2000/svg" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="#34d399" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M11 20A7 7 0 0 1 9.8 6.1C15.5 5 17 4.48 19 2c1 2 2 4.18 2 8h-5a7 7 0 0 0-7 7l-2 3Z"/><path d="M11 20v-3"/><path d="m9 20-1-2"/></svg>
              </div>
              <span class="text-emerald-400 font-semibold text-sm tracking-wide uppercase">Sustainability</span>
            </div>
          </div>
          <div class="p-8 lg:p-10">
            <h3 class="text-2xl font-bold text-white mb-4 tracking-tight">Environmental Stewardship</h3>
            <p class="text-white/60 leading-relaxed">
              Backing renewable energy, circular economy frameworks, and advanced recycling infrastructure. We focus on waste-to-value initiatives that systematically reduce environmental footprints while creating local economic opportunity.
            </p>
          </div>
        </div>

        <!-- Community Health -->
        <div class="rounded-2xl border border-white/10 bg-white/[0.03] overflow-hidden">
          <div class="relative h-56">
            <img
              src="https://images.pexels.com/photos/6646967/pexels-photo-6646967.jpeg?auto=compress&cs=tinysrgb&w=800"
              alt="Healthcare worker providing care in a community setting"
              class="w-full h-full object-cover"
              loading="lazy"
            />
            <div class="absolute inset-0 bg-gradient-to-t from-dark/90 to-transparent"></div>
            <div class="absolute bottom-4 left-6 flex items-center gap-3">
              <div class="w-9 h-9 rounded-lg bg-rose-500/20 flex items-center justify-center">
                <svg xmlns="http://www.w3.org/2000/svg" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="#fb7185" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M19 14c1.49-1.46 3-3.21 3-5.5A5.5 5.5 0 0 0 16.5 3c-1.76 0-3 .5-4.5 2-1.5-1.5-2.74-2-4.5-2A5.5 5.5 0 0 0 2 8.5c0 2.3 1.5 4.05 3 5.5l7 7Z"/></svg>
              </div>
              <span class="text-rose-400 font-semibold text-sm tracking-wide uppercase">Community Health</span>
            </div>
          </div>
          <div class="p-8 lg:p-10">
            <h3 class="text-2xl font-bold text-white mb-4 tracking-tight">Strengthening Community Well-Being</h3>
            <p class="text-white/60 leading-relaxed">
              Investing in healthcare accessibility, crisis-response infrastructure, and preventive care initiatives. We fund essential services that build resilient communities capable of sustaining long-term health outcomes.
            </p>
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- Submit a Proposal -->
  <section class="py-24 md:py-32 bg-surface relative overflow-hidden">
    <div class="container mx-auto px-4 relative z-10">
      <div class="grid grid-cols-1 lg:grid-cols-2 gap-16 lg:gap-20 items-start">
        <!-- Left: messaging -->
        <div class="lg:sticky lg:top-32">
          <p class="text-secondary font-semibold text-sm tracking-widest uppercase mb-4">Collaborate With Us</p>
          <h2 class="text-3xl md:text-5xl font-bold text-dark mb-6 tracking-tight leading-tight">Partner For Impact</h2>
          <p class="text-lg text-muted-foreground leading-relaxed mb-8">
            Are you an NGO, community leader, or sustainability operator aligned with our mission? Submit your proposal and let us explore how SPVH capital and strategic guidance can amplify your impact.
          </p>
          <div class="space-y-4 text-muted-foreground">
            <div class="flex items-start gap-3">
              <svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="var(--color-secondary)" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="mt-0.5 shrink-0"><polyline points="20 6 9 17 4 12"/></svg>
              <span>Proposals reviewed within 10 business days</span>
            </div>
            <div class="flex items-start gap-3">
              <svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="var(--color-secondary)" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="mt-0.5 shrink-0"><polyline points="20 6 9 17 4 12"/></svg>
              <span>Funding for education, sustainability, and health initiatives</span>
            </div>
            <div class="flex items-start gap-3">
              <svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="var(--color-secondary)" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="mt-0.5 shrink-0"><polyline points="20 6 9 17 4 12"/></svg>
              <span>Strategic guidance beyond capital</span>
            </div>
          </div>
        </div>

        <!-- Right: form -->
        <div>
          <div id="proposal-status" class="hidden mb-6 px-4 py-3 rounded-lg text-sm"></div>

          <form id="proposal-form" class="space-y-5 bg-dark p-8 lg:p-10 rounded-2xl border border-white/10 shadow-2xl">
            <div class="grid grid-cols-1 sm:grid-cols-2 gap-5">
              <div class="space-y-2">
                <label class="text-[11px] font-bold text-dark-muted uppercase tracking-wider">Organisation *</label>
                <input
                  type="text" name="org_name" required placeholder="NGO / Organisation"
                  class="w-full bg-transparent border border-white/10 rounded-lg px-4 py-3 text-white focus:outline-none focus:border-secondary transition-colors"
                />
              </div>
              <div class="space-y-2">
                <label class="text-[11px] font-bold text-dark-muted uppercase tracking-wider">Contact Person *</label>
                <input
                  type="text" name="contact_person" required placeholder="Full Name"
                  class="w-full bg-transparent border border-white/10 rounded-lg px-4 py-3 text-white focus:outline-none focus:border-secondary transition-colors"
                />
              </div>
            </div>

            <div class="grid grid-cols-1 sm:grid-cols-2 gap-5">
              <div class="space-y-2">
                <label class="text-[11px] font-bold text-dark-muted uppercase tracking-wider">Email *</label>
                <input
                  type="email" name="email" required placeholder="you@organisation.org"
                  class="w-full bg-transparent border border-white/10 rounded-lg px-4 py-3 text-white focus:outline-none focus:border-secondary transition-colors"
                />
              </div>
              <div class="space-y-2">
                <label class="text-[11px] font-bold text-dark-muted uppercase tracking-wider">Phone</label>
                <input
                  type="tel" name="phone" placeholder="+91 98765 43210"
                  class="w-full bg-transparent border border-white/10 rounded-lg px-4 py-3 text-white focus:outline-none focus:border-secondary transition-colors"
                />
              </div>
            </div>

            <div class="space-y-2">
              <label class="text-[11px] font-bold text-dark-muted uppercase tracking-wider">Focus Area *</label>
              <select
                name="focus_area" required
                class="w-full bg-dark border border-white/10 rounded-lg px-4 py-3 text-white focus:outline-none focus:border-secondary transition-colors appearance-none"
              >
                <option value="" disabled selected>Select a focus area</option>
                <option value="Education">Education</option>
                <option value="Environmental Sustainability">Environmental Sustainability</option>
                <option value="Community Health">Community Health</option>
                <option value="Other">Other</option>
              </select>
            </div>

            <div class="space-y-2">
              <label class="text-[11px] font-bold text-dark-muted uppercase tracking-wider">Proposal Summary *</label>
              <textarea
                name="summary" required rows="4" placeholder="Describe your proposal, its objectives, and the impact you envision..."
                class="w-full bg-transparent border border-white/10 rounded-lg px-4 py-3 text-white focus:outline-none focus:border-secondary transition-colors resize-none"
              ></textarea>
            </div>

            <div class="space-y-2">
              <label class="text-[11px] font-bold text-dark-muted uppercase tracking-wider">Attach Proposal (PDF, max 5 MB)</label>
              <label id="proposal-file-label" class="flex items-center gap-3 w-full border border-dashed border-white/15 rounded-lg px-4 py-4 cursor-pointer hover:border-secondary/40 transition-colors group">
                <svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="text-dark-muted group-hover:text-secondary transition-colors shrink-0"><path d="M21.44 11.05l-9.19 9.19a6 6 0 0 1-8.49-8.49l9.19-9.19a4 4 0 0 1 5.66 5.66l-9.2 9.19a2 2 0 0 1-2.83-2.83l8.49-8.49"/></svg>
                <span id="proposal-file-name" class="text-dark-muted text-sm group-hover:text-white transition-colors">Click to select a PDF file</span>
                <input
                  type="file" name="proposal_file" accept=".pdf" class="hidden" id="proposal-file-input"
                />
              </label>
            </div>

            <input type="text" name="_hp_website" autocomplete="off" tabindex="-1" aria-hidden="true" style="position:absolute;left:-9999px;opacity:0;height:0;width:0;overflow:hidden" />

            <button
              type="submit" id="proposal-submit"
              class="w-full bg-secondary text-white font-bold uppercase tracking-wider py-4 rounded-xl hover:bg-secondary-hover active:scale-[0.98] transition-all shadow-lg">
              Submit Proposal
            </button>
          </form>
        </div>
      </div>
    </div>
  </section>

  <script is:inline define:vars={{ FORMS_ENDPOINT: FORMS.endpoint }}>
    document.addEventListener("DOMContentLoaded", function() {
      var proposalForm = document.getElementById("proposal-form");
      var proposalStatus = document.getElementById("proposal-status");
      var proposalSubmit = document.getElementById("proposal-submit");
      var proposalFileInput = document.getElementById("proposal-file-input");
      var proposalFileName = document.getElementById("proposal-file-name");

      proposalFileInput.addEventListener("change", function() {
        var file = proposalFileInput.files[0];
        if (file) {
          if (file.size > 5 * 1024 * 1024) {
            proposalFileName.textContent = "File too large. Max 5 MB.";
            proposalFileInput.value = "";
            return;
          }
          if (file.type !== "application/pdf") {
            proposalFileName.textContent = "Only PDF files are accepted.";
            proposalFileInput.value = "";
            return;
          }
          proposalFileName.textContent = file.name;
        } else {
          proposalFileName.textContent = "Click to select a PDF file";
        }
      });

      proposalForm.addEventListener("submit", async function(e) {
        e.preventDefault();
        proposalSubmit.disabled = true;
        proposalSubmit.textContent = "SUBMITTING...";

        var formData = new FormData(proposalForm);

        if (formData.get("_hp_website")) {
          proposalStatus.className = "mb-6 px-4 py-3 rounded-lg bg-secondary/20 border border-secondary text-secondary text-sm";
          proposalStatus.textContent = "Thank you! Your proposal has been submitted.";
          proposalStatus.classList.remove("hidden");
          proposalForm.reset();
          proposalFileName.textContent = "Click to select a PDF file";
          proposalSubmit.disabled = false;
          proposalSubmit.textContent = "Submit Proposal";
          return;
        }

        var payload = {
          _formType: "proposal",
          org_name: formData.get("org_name"),
          contact_person: formData.get("contact_person"),
          email: formData.get("email"),
          phone: formData.get("phone") || "",
          focus_area: formData.get("focus_area"),
          summary: formData.get("summary"),
        };

        var file = proposalFileInput.files[0];
        if (file) {
          try {
            var buffer = await file.arrayBuffer();
            var bytes = new Uint8Array(buffer);
            var binary = "";
            for (var i = 0; i < bytes.length; i++) {
              binary += String.fromCharCode(bytes[i]);
            }
            payload._files = [{
              name: file.name,
              type: file.type,
              data: btoa(binary),
            }];
          } catch (err) {}
        }

        try {
          await fetch(FORMS_ENDPOINT, {
            method: "POST",
            mode: "no-cors",
            body: JSON.stringify(payload),
          });

          proposalStatus.className = "mb-6 px-4 py-3 rounded-lg bg-secondary/20 border border-secondary text-secondary text-sm";
          proposalStatus.textContent = "Thank you! Your proposal has been submitted successfully. We will review it and get back to you.";
          proposalStatus.classList.remove("hidden");
          proposalForm.reset();
          proposalFileName.textContent = "Click to select a PDF file";
        } catch (err) {
          proposalStatus.className = "mb-6 px-4 py-3 rounded-lg bg-red-500/20 border border-red-500 text-red-500 text-sm";
          proposalStatus.textContent = "Failed to submit. Please try again or email us directly at info@spvhgroup.com.";
          proposalStatus.classList.remove("hidden");
        } finally {
          proposalSubmit.disabled = false;
          proposalSubmit.textContent = "Submit Proposal";
        }
      });
    });
  </script>
</BaseLayout>
