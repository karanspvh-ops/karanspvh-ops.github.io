---
import BaseLayout from '@/layouts/BaseLayout.astro';
import { SITE } from '@/config/site';

const jsonLd = {
  "@context": "https://schema.org",
  "@type": "WebPage",
  "name": "CSR & Philanthropy | SPVH Group",
  "description": "Fostering positive change through sustainable projects and meaningful partnerships.",
  "url": `${SITE.url}csr-philanthropy`
};
---

<BaseLayout title="CSR & Philanthropy | SPVH Group" description="Our corporate social responsibility initiatives are dedicated to fostering positive change through sustainable projects and meaningful partnerships." jsonLd={jsonLd}>
  <!-- Section 1: Hero Header -->
  <section class="relative min-h-[60vh] flex items-center pt-20 overflow-hidden" data-ps="src/pages/csr-philanthropy.astro:srk0b5">
    <div class="absolute inset-0 z-0" data-ps="src/pages/csr-philanthropy.astro:exvgno">
      <img 
        src="https://images.pexels.com/photos/6837810/pexels-photo-6837810.png?auto=compress&cs=tinysrgb&w=1200"
        srcset="https://images.pexels.com/photos/6837810/pexels-photo-6837810.png?auto=compress&cs=tinysrgb&w=320 320w, https://images.pexels.com/photos/6837810/pexels-photo-6837810.png?auto=compress&cs=tinysrgb&w=480 480w, https://images.pexels.com/photos/6837810/pexels-photo-6837810.png?auto=compress&cs=tinysrgb&w=640 640w, https://images.pexels.com/photos/6837810/pexels-photo-6837810.png?auto=compress&cs=tinysrgb&w=768 768w, https://images.pexels.com/photos/6837810/pexels-photo-6837810.png?auto=compress&cs=tinysrgb&w=1024 1024w, https://images.pexels.com/photos/6837810/pexels-photo-6837810.png?auto=compress&cs=tinysrgb&w=1280 1280w, https://images.pexels.com/photos/6837810/pexels-photo-6837810.png?auto=compress&cs=tinysrgb&w=1920 1920w"
        sizes="100vw"
        alt="Sustainable Landscape" 
        class="w-full h-full object-cover"
        fetchpriority="high"
        loading="eager" data-ps="src/pages/csr-philanthropy.astro:hg4kz8" />
      <div class="absolute inset-0 bg-dark/80" data-ps="src/pages/csr-philanthropy.astro:exvgnn"></div>
    </div>
    
    <div class="container mx-auto px-4 relative z-10" data-ps="src/pages/csr-philanthropy.astro:exvgnm">
      <div class="max-w-4xl hero-animate" data-ps="src/pages/csr-philanthropy.astro:exvgnl">
        <h1 class="text-4xl md:text-7xl font-bold text-white mb-6 tracking-tight" data-ps="src/pages/csr-philanthropy.astro:wsxg0x">
          CSR & Philanthropy: <span class="text-secondary" data-ps="src/pages/csr-philanthropy.astro:ptnds">Beyond Capital</span>
        </h1>
        <p class="text-xl md:text-2xl text-white/90 font-medium leading-relaxed max-w-3xl" data-ps="src/pages/csr-philanthropy.astro:qafpqf">
          Our corporate social responsibility initiatives are dedicated to fostering positive change through sustainable projects and meaningful partnerships. We believe in philanthropy that makes a lasting, tangible impact, enriching communities and supporting causes that align with our core institutional values.
        </p>
      </div>
    </div>
  </section>

  <!-- Section 2: Core Impact Pillars -->
  <section class="py-24 bg-dark relative overflow-hidden" data-ps="src/pages/csr-philanthropy.astro:srk0b6">
    <div class="container mx-auto px-4 relative z-10" data-ps="src/pages/csr-philanthropy.astro:exvgnk">
      <div class="grid grid-cols-1 lg:grid-cols-3 gap-8" data-ps="src/pages/csr-philanthropy.astro:u9os2w">
        <!-- Card 1: Empowering Education -->
        <div class="bg-dark border border-white/5 p-10 rounded-2xl flex flex-col h-full shadow-2xl" data-ps="src/pages/csr-philanthropy.astro:u9os2v">
          <div class="w-14 h-14 bg-secondary/10 rounded-xl flex items-center justify-center mb-8" data-ps="src/pages/csr-philanthropy.astro:u9os2u">
            <svg xmlns="http://www.w3.org/2000/svg" width="28" height="28" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M2 3h6a4 4 0 0 1 4 4v14a3 3 0 0 0-3-3H2z"/><path d="M22 3h-6a4 4 0 0 0-4 4v14a3 3 0 0 1 3-3h7z"/></svg>
          </div>
          <h3 class="text-2xl font-bold text-white mb-6" data-ps="src/pages/csr-philanthropy.astro:8vcrie">Empowering Education</h3>
          <p class="text-dark-muted leading-relaxed flex-grow" data-ps="src/pages/csr-philanthropy.astro:qafpqg">
            Nurturing future leaders through targeted skill-building programs and accessibility initiatives. We invest in educational frameworks that bridge the opportunity gap and equip the next generation with modern, market-relevant competencies.
          </p>
        </div>

        <!-- Card 2: Environmental Sustainability -->
        <div class="bg-dark border border-white/5 p-10 rounded-2xl flex flex-col h-full shadow-2xl" data-ps="src/pages/csr-philanthropy.astro:u9os2t">
          <div class="w-14 h-14 bg-secondary/10 rounded-xl flex items-center justify-center mb-8" data-ps="src/pages/csr-philanthropy.astro:u9os2s">
            <svg xmlns="http://www.w3.org/2000/svg" width="28" height="28" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M11 20A7 7 0 0 1 9.8 6.1C15.5 5 17 4.48 19 2c1 2 2 4.18 2 8h-5a7 7 0 0 0-7 7l-2 3Z"/><path d="M9.17 14.85a1 1 0 1 1-1.42-1.42 1 1 0 0 1 1.42 1.42ZM11 20v-3"/><path d="m9 20-1-2"/></svg>
          </div>
          <h3 class="text-2xl font-bold text-white mb-6" data-ps="src/pages/csr-philanthropy.astro:8vcrif">Environmental Sustainability</h3>
          <p class="text-dark-muted leading-relaxed flex-grow" data-ps="src/pages/csr-philanthropy.astro:qafpqh">
            Backing green initiatives and renewable energy projects for a cleaner future. We actively support circular economy frameworks, focusing on advanced recycling infrastructure and waste-to-value initiatives to systematically minimize environmental footprints.
          </p>
        </div>

        <!-- Card 3: Community Health -->
        <div class="bg-dark border border-white/5 p-10 rounded-2xl flex flex-col h-full shadow-2xl" data-ps="src/pages/csr-philanthropy.astro:u9os2r">
          <div class="w-14 h-14 bg-secondary/10 rounded-xl flex items-center justify-center mb-8" data-ps="src/pages/csr-philanthropy.astro:u9os2q">
            <svg xmlns="http://www.w3.org/2000/svg" width="28" height="28" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M19 14c1.49-1.46 3-3.21 3-5.5A5.5 5.5 0 0 0 16.5 3c-1.76 0-3 .5-4.5 2-1.5-1.5-2.74-2-4.5-2A5.5 5.5 0 0 0 2 8.5c0 2.3 1.5 4.05 3 5.5l7 7Z"/></svg>
          </div>
          <h3 class="text-2xl font-bold text-white mb-6" data-ps="src/pages/csr-philanthropy.astro:8vcrig">Community Health</h3>
          <p class="text-dark-muted leading-relaxed flex-grow" data-ps="src/pages/csr-philanthropy.astro:qafpqi">
            Investing in healthcare accessibility and supporting resilient local communities. Our health initiatives are designed to strengthen community well-being by funding essential services and crisis-response infrastructure.
          </p>
        </div>
      </div>
    </div>
  </section>

  <!-- Section 3: Submit a Proposal -->
  <section class="py-24 bg-surface relative overflow-hidden" data-ps="src/pages/csr-philanthropy.astro:srk0b7">
    <div class="absolute inset-0 opacity-[0.03] pointer-events-none" style="background-image: radial-gradient(var(--color-secondary) 1px, transparent 1px); background-size: 40px 40px;"></div>

    <div class="container mx-auto px-4 relative z-10">
      <div class="max-w-2xl mx-auto">
        <div class="text-center mb-12">
          <h2 class="text-3xl md:text-5xl font-bold text-dark mb-6 tracking-tight">Partner For Impact</h2>
          <p class="text-xl text-muted-foreground leading-relaxed">
            Are you an NGO, community leader, or sustainability operator aligning with our mission? Submit your proposal and let us explore how SPVH capital and strategic guidance can scale your impact.
          </p>
        </div>

        <div id="proposal-status" class="hidden mb-6 px-4 py-3 rounded-lg text-sm"></div>

        <form id="proposal-form" class="space-y-6 bg-dark p-8 lg:p-12 rounded-2xl border border-white/10 shadow-2xl">
          <div class="grid grid-cols-1 sm:grid-cols-2 gap-6">
            <div class="space-y-2">
              <label class="text-[12px] font-bold text-dark-muted uppercase">Organisation Name *</label>
              <input
                type="text" name="org_name" required placeholder="NGO / Organisation"
                class="w-full bg-transparent border border-white/10 rounded-lg px-4 py-3 text-white focus:outline-none focus:border-primary transition-colors"
              />
            </div>
            <div class="space-y-2">
              <label class="text-[12px] font-bold text-dark-muted uppercase">Contact Person *</label>
              <input
                type="text" name="contact_person" required placeholder="Full Name"
                class="w-full bg-transparent border border-white/10 rounded-lg px-4 py-3 text-white focus:outline-none focus:border-primary transition-colors"
              />
            </div>
          </div>

          <div class="grid grid-cols-1 sm:grid-cols-2 gap-6">
            <div class="space-y-2">
              <label class="text-[12px] font-bold text-dark-muted uppercase">Email *</label>
              <input
                type="email" name="email" required placeholder="you@organisation.org"
                class="w-full bg-transparent border border-white/10 rounded-lg px-4 py-3 text-white focus:outline-none focus:border-primary transition-colors"
              />
            </div>
            <div class="space-y-2">
              <label class="text-[12px] font-bold text-dark-muted uppercase">Phone (Optional)</label>
              <input
                type="tel" name="phone" placeholder="+91 98765 43210"
                class="w-full bg-transparent border border-white/10 rounded-lg px-4 py-3 text-white focus:outline-none focus:border-primary transition-colors"
              />
            </div>
          </div>

          <div class="space-y-2">
            <label class="text-[12px] font-bold text-dark-muted uppercase">Focus Area *</label>
            <select
              name="focus_area" required
              class="w-full bg-dark border border-white/10 rounded-lg px-4 py-3 text-white focus:outline-none focus:border-primary transition-colors appearance-none"
            >
              <option value="" disabled selected>Select a focus area</option>
              <option value="Education">Education</option>
              <option value="Environmental Sustainability">Environmental Sustainability</option>
              <option value="Community Health">Community Health</option>
              <option value="Other">Other</option>
            </select>
          </div>

          <div class="space-y-2">
            <label class="text-[12px] font-bold text-dark-muted uppercase">Proposal Summary *</label>
            <textarea
              name="summary" required rows="4" placeholder="Briefly describe your proposal, its objectives, and the impact you envision..."
              class="w-full bg-transparent border border-white/10 rounded-lg px-4 py-3 text-white focus:outline-none focus:border-primary transition-colors resize-none"
            ></textarea>
          </div>

          <div class="space-y-2">
            <label class="text-[12px] font-bold text-dark-muted uppercase">Attach Proposal (PDF, max 5 MB)</label>
            <label id="proposal-file-label" class="flex items-center gap-3 w-full border border-dashed border-white/20 rounded-lg px-4 py-4 cursor-pointer hover:border-secondary/50 transition-colors group">
              <svg xmlns="http://www.w3.org/2000/svg" width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="text-dark-muted group-hover:text-secondary transition-colors shrink-0"><path d="M21.44 11.05l-9.19 9.19a6 6 0 0 1-8.49-8.49l9.19-9.19a4 4 0 0 1 5.66 5.66l-9.2 9.19a2 2 0 0 1-2.83-2.83l8.49-8.49"/></svg>
              <span id="proposal-file-name" class="text-dark-muted text-sm group-hover:text-white transition-colors">Click to select a PDF file</span>
              <input
                type="file" name="proposal_file" accept=".pdf" class="hidden" id="proposal-file-input"
              />
            </label>
          </div>

          <input type="text" name="_hp_website" autocomplete="off" tabindex="-1" aria-hidden="true" style="position:absolute;left:-9999px;opacity:0;height:0;width:0;overflow:hidden" />

          <button
            type="submit" id="proposal-submit"
            class="w-full bg-secondary text-white font-bold uppercase tracking-wider py-4 rounded-xl hover:bg-secondary-hover transition-colors shadow-lg">
            SUBMIT PROPOSAL
          </button>
        </form>
      </div>
    </div>
  </section>

  <script is:inline>
    document.addEventListener("DOMContentLoaded", function() {
      var proposalForm = document.getElementById("proposal-form");
      var proposalStatus = document.getElementById("proposal-status");
      var proposalSubmit = document.getElementById("proposal-submit");
      var proposalFileInput = document.getElementById("proposal-file-input");
      var proposalFileName = document.getElementById("proposal-file-name");

      proposalFileInput.addEventListener("change", function() {
        var file = proposalFileInput.files[0];
        if (file) {
          if (file.size > 5 * 1024 * 1024) {
            proposalFileName.textContent = "File too large. Max 5 MB.";
            proposalFileInput.value = "";
            return;
          }
          if (file.type !== "application/pdf") {
            proposalFileName.textContent = "Only PDF files are accepted.";
            proposalFileInput.value = "";
            return;
          }
          proposalFileName.textContent = file.name;
        } else {
          proposalFileName.textContent = "Click to select a PDF file";
        }
      });

      proposalForm.addEventListener("submit", async function(e) {
        e.preventDefault();
        proposalSubmit.disabled = true;
        proposalSubmit.textContent = "SUBMITTING...";

        var formData = new FormData(proposalForm);

        if (formData.get("_hp_website")) {
          proposalStatus.className = "mb-6 px-4 py-3 rounded-lg bg-secondary/20 border border-secondary text-secondary text-sm";
          proposalStatus.textContent = "Thank you! Your proposal has been submitted.";
          proposalStatus.classList.remove("hidden");
          proposalForm.reset();
          proposalFileName.textContent = "Click to select a PDF file";
          proposalSubmit.disabled = false;
          proposalSubmit.textContent = "SUBMIT PROPOSAL";
          return;
        }

        var payload = {
          _formType: "proposal",
          org_name: formData.get("org_name"),
          contact_person: formData.get("contact_person"),
          email: formData.get("email"),
          phone: formData.get("phone") || "",
          focus_area: formData.get("focus_area"),
          summary: formData.get("summary"),
        };

        var file = proposalFileInput.files[0];
        if (file) {
          try {
            var buffer = await file.arrayBuffer();
            var bytes = new Uint8Array(buffer);
            var binary = "";
            for (var i = 0; i < bytes.length; i++) {
              binary += String.fromCharCode(bytes[i]);
            }
            payload._files = [{
              name: file.name,
              type: file.type,
              data: btoa(binary),
            }];
          } catch (err) {}
        }

        try {
          await fetch("https://script.google.com/macros/s/AKfycbx3Zm67d3faiGLVl7eMxk9dv9mU2FQyMg9JusKHzpv9oCN_C2E111XJ5IQUmKwYzCMXkg/exec", {
            method: "POST",
            mode: "no-cors",
            body: JSON.stringify(payload),
          });

          proposalStatus.className = "mb-6 px-4 py-3 rounded-lg bg-secondary/20 border border-secondary text-secondary text-sm";
          proposalStatus.textContent = "Thank you! Your proposal has been submitted successfully. We will review it and get back to you.";
          proposalStatus.classList.remove("hidden");
          proposalForm.reset();
          proposalFileName.textContent = "Click to select a PDF file";
        } catch (err) {
          proposalStatus.className = "mb-6 px-4 py-3 rounded-lg bg-red-500/20 border border-red-500 text-red-500 text-sm";
          proposalStatus.textContent = "Failed to submit. Please try again or email us directly at info@spvhgroup.com.";
          proposalStatus.classList.remove("hidden");
        } finally {
          proposalSubmit.disabled = false;
          proposalSubmit.textContent = "SUBMIT PROPOSAL";
        }
      });
    });
  </script>
</BaseLayout>
