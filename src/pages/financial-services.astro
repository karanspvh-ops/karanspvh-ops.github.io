---
import BaseLayout from '@/layouts/BaseLayout.astro';
import VerticalNav from '@/components/VerticalNav.astro';

const jsonLd = {
  "@context": "https://schema.org",
  "@type": "WebPage",
  "name": "Financial Services | SPVH Group",
  "description": "SPVH Group delivers a sophisticated suite of wealth and investment solutions including AIF, PMS, and venture capital.",
  "url": "https://spvhgroup.com/financial-services"
};
---

<BaseLayout title="Financial Services | AIF, PMS & Venture Capital — SPVH Group" description="SPVH Group's financial services vertical: alternative investment funds, portfolio management services, and venture capital for institutional and UHNI clients." jsonLd={jsonLd}>
  <main data-ps="src/pages/financial-services.astro:weor7w">
    <!-- Section 1: Vertical Hero & Overview -->
    <section class="relative min-h-[90vh] max-h-[90vh] flex items-center pt-20 overflow-hidden bg-dark" data-ps="src/pages/financial-services.astro:hero">
      <div class="absolute inset-0 z-0" data-ps="src/pages/financial-services.astro:hero-bg">
        <img 
          src="https://images.unsplash.com/photo-1618044733300-9472054094ee?crop=entropy&cs=tinysrgb&fit=max&fm=jpg&ixid=M3w4MTQzNzh8MHwxfHNlYXJjaHw4fHxzdG9ja3xlbnwwfHx8fDE3NzU4MTkwNjF8MA&ixlib=rb-4.1.0&q=80&w=1200&auto=format"
          sizes="100vw"
          alt="Modern architecture glass skyscraper financial district" 
          class="w-full h-full object-cover opacity-60" 
          loading="eager" 
          fetchpriority="high" data-ps="src/pages/financial-services.astro:153l89" crossorigin="anonymous" />
        <div class="absolute inset-0 bg-gradient-to-r from-dark via-dark/40 to-transparent" data-ps="src/pages/financial-services.astro:hero-overlay"></div>
      </div>

      <div class="container mx-auto px-6 relative z-10" data-ps="src/pages/financial-services.astro:hero-content">
        <div class="max-w-3xl hero-animate" data-ps="src/pages/financial-services.astro:sq5dez">
          <a href="/#businesses" class="inline-block px-4 py-1 rounded-full bg-primary/20 backdrop-blur-md border border-primary/30 text-white text-sm font-bold uppercase tracking-widest mb-6 hover:bg-primary/40 transition-colors cursor-pointer" data-ps="src/pages/financial-services.astro:nhai6p">Business Vertical</a>
          <h1 class="text-5xl md:text-7xl font-bold text-white mb-8 leading-[1.1]" data-ps="src/pages/financial-services.astro:h1">
          <span class="text-primary uppercase flex flex-col justify-end min-h-[2.2em]" data-ps="src/pages/financial-services.astro:nhai6q">
            <span data-ps="src/pages/financial-services.astro:nhai6r">FINANCIAL</span>
            <span data-ps="src/pages/financial-services.astro:nhai6s">SERVICES</span>
          </span>
          <span class="block mt-4 text-2xl md:text-3xl font-normal text-dark-muted" data-ps="src/pages/financial-services.astro:nhai6s">Unmatched Return Portfolios.</span>
        </h1>
          <div class="bg-white/10 backdrop-blur-xl border border-white/20 p-8 rounded-2xl shadow-2xl" data-ps="src/pages/financial-services.astro:sq5df0">
            <p class="text-xl text-dark-muted leading-relaxed" data-ps="src/pages/financial-services.astro:p1">
              SPVH Group delivers a sophisticated suite of wealth and investment solutions, encompassing Alternative Investment Funds (AIF), Portfolio Management Services (PMS), strategic equity investments, and comprehensive family office management. Exclusively serving institutional and UHNI clientele across the ASEAN and European regions, we actively pursue scalable global acquisitions and currently manage assets in excess of USD 300 Million.
            </p>
          </div>
        </div>
      </div>
    </section>

    <VerticalNav activePath="/financial-services" />

    <!-- Section: Intro Text -->
    <section class="relative pt-20 pb-16 bg-surface overflow-hidden" data-ps="src/pages/financial-services.astro:intro-text-section">
      <!-- Background Art / Pattern -->
      <div class="absolute inset-0 z-0 pointer-events-none" data-ps="src/pages/financial-services.astro:intro-bg-art">
        <img 
          src="/images/SPVH-Patterns-2-1536.webp" 
          alt="Geometric pattern background" 
          class="w-full h-full object-cover opacity-10" data-ps="src/pages/financial-services.astro:153l89" />
        <div class="absolute inset-0 bg-gradient-to-b from-surface via-transparent to-surface" data-ps="src/pages/financial-services.astro:sq5df0"></div>
      </div>
      
      <div class="container mx-auto px-6 max-w-[900px] text-center relative z-10" data-ps="src/pages/financial-services.astro:intro-container">
        <h2 class="text-3xl md:text-4xl font-bold text-primary mb-6" data-ps="src/pages/financial-services.astro:intro-heading">
          The Strategic Engine of SPVH Group
        </h2>
        <p class="text-lg md:text-[20px] text-secondary leading-[1.6] font-medium italic" data-ps="src/pages/financial-services.astro:intro-body">
          "We operate at the intersection of deep market intelligence and quantitative rigor, engineering resilient, risk-adjusted portfolios for UHNIs and institutional partners worldwide."
        </p>
      </div>
    </section>

    <!-- Section: Our Philosophy (Remodeled) -->
    <section class="py-24 bg-dark" data-ps="src/pages/financial-services.astro:philosophy-section">
      <div class="container px-6 mx-auto max-w-[1400px]" data-ps="src/pages/financial-services.astro:philosophy-container">
        <div class="text-center max-w-4xl mx-auto mb-20" data-ps="src/pages/financial-services.astro:philosophy-header">
          <span class="block text-secondary text-sm font-bold uppercase tracking-[0.2em] mb-4" data-ps="src/pages/financial-services.astro:philosophy-kicker">OUR PHILOSOPHY</span>
          <h2 class="text-4xl md:text-5xl font-bold text-white leading-tight" data-ps="src/pages/financial-services.astro:philosophy-h2">
            Quantitative Rigor, Uncompromising Discipline.
          </h2>
        </div>

        <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-4 gap-8" data-ps="src/pages/financial-services.astro:philosophy-grid">
          <!-- Card 1 -->
          <div class="bg-dark/90 border border-primary p-[30px] rounded-2xl flex flex-col h-full text-center" data-ps="src/pages/financial-services.astro:phil-card-1">
            <div class="flex items-center justify-center mb-6" data-ps="src/pages/financial-services.astro:sq5det">
              <h3 class="text-[22px] font-bold text-secondary" data-ps="src/pages/financial-services.astro:phil-title-1">Quantitative Analysis</h3>
            </div>
            <div class="flex items-start justify-center flex-grow" data-ps="src/pages/financial-services.astro:sq5deu">
              <p class="text-dark-muted leading-[1.5] font-normal" data-ps="src/pages/financial-services.astro:phil-body-1">
                We apply a research-first approach, leveraging robust data analytics and econometric modeling to drive all portfolio construction and risk decisions.
              </p>
            </div>
          </div>

          <!-- Card 2 -->
          <div class="bg-dark/90 border border-primary p-[30px] rounded-2xl flex flex-col h-full text-center" data-ps="src/pages/financial-services.astro:phil-card-2">
            <div class="flex items-center justify-center mb-6" data-ps="src/pages/financial-services.astro:sq5dev">
              <h3 class="text-[22px] font-bold text-secondary" data-ps="src/pages/financial-services.astro:phil-title-2">Capital Allocation</h3>
            </div>
            <div class="flex items-start justify-center flex-grow" data-ps="src/pages/financial-services.astro:sq5dew">
              <p class="text-dark-muted leading-[1.5] font-normal" data-ps="src/pages/financial-services.astro:phil-body-2">
                Every investment decision is optimized for capital efficiency, prioritizing sustained, uncorrelated yield through strategic asset diversification.
              </p>
            </div>
          </div>

          <!-- Card 3 -->
          <div class="bg-dark/90 border border-primary p-[30px] rounded-2xl flex flex-col h-full text-center" data-ps="src/pages/financial-services.astro:phil-card-3">
            <div class="flex items-center justify-center mb-6" data-ps="src/pages/financial-services.astro:sq5dex">
              <h3 class="text-[22px] font-bold text-secondary" data-ps="src/pages/financial-services.astro:phil-title-3">Advanced Technology</h3>
            </div>
            <div class="flex items-start justify-center flex-grow" data-ps="src/pages/financial-services.astro:sq5dey">
              <p class="text-dark-muted leading-[1.5] font-normal" data-ps="src/pages/financial-services.astro:phil-body-3">
                We seamlessly integrate FinTech ecosystems to provide institutional-grade reporting, precise portfolio modeling, and real-time market intelligence.
              </p>
            </div>
          </div>

          <!-- Card 4 -->
          <div class="bg-dark/90 border border-primary p-[30px] rounded-2xl flex flex-col h-full text-center" data-ps="src/pages/financial-services.astro:phil-card-4">
            <div class="flex items-center justify-center mb-6" data-ps="src/pages/financial-services.astro:sq5dez">
              <h3 class="text-[22px] font-bold text-secondary" data-ps="src/pages/financial-services.astro:phil-title-4">Resilient Wealth</h3>
            </div>
            <div class="flex items-start justify-center flex-grow" data-ps="src/pages/financial-services.astro:sq5df0">
              <p class="text-dark-muted leading-[1.5] font-normal" data-ps="src/pages/financial-services.astro:phil-body-4">
                Our focus is strictly long-term, designing portfolios to maximize risk-adjusted returns and preserve generational wealth through disciplined volatility management.
              </p>
            </div>
          </div>
        </div>
      </div>
    </section>

    <!-- Section: Financial Services Offerings -->
    <section class="py-24 bg-white" data-ps="src/pages/financial-services.astro:financial-offerings">
    <div class="container px-6 mx-auto max-w-[1400px]" data-ps="src/pages/financial-services.astro:offerings-container">
    <div class="text-center max-w-4xl mx-auto mb-20" data-ps="src/pages/financial-services.astro:offerings-header">
    <span class="block text-secondary text-sm font-bold uppercase tracking-[0.2em] mb-4" data-ps="src/pages/financial-services.astro:offerings-kicker">WHAT WE OFFER</span>
    <h2 class="text-4xl md:text-5xl font-bold leading-tight" data-ps="src/pages/financial-services.astro:offerings-h2">
    <span class="text-dark" data-ps="src/pages/financial-services.astro:nhai6n">Bespoke Solutions Designed for</span>
    <span class="text-primary" data-ps="src/pages/financial-services.astro:nhai6o">Serious Investors & Business.</span>
    </h2>
    </div>

    <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-4 gap-8" data-ps="src/pages/financial-services.astro:offerings-grid">
    <!-- Card 1 -->
    <div class="bg-white border border-border hover:border-secondary/40 p-10 rounded-2xl overflow-hidden shadow-[0_10px_40px_rgba(0,0,0,0.06)] flex flex-col h-full hover:translate-y-[-4px] transition-transform duration-300" data-ps="src/pages/financial-services.astro:offering-card-1">
    <div class="text-primary mb-6" data-ps="src/pages/financial-services.astro:offering-icon-1">
    <svg xmlns="http://www.w3.org/2000/svg" width="32" height="32" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="lucide lucide-briefcase"><rect width="20" height="14" x="2" y="7" rx="2" ry="2"/><path d="M16 21V5a2 2 0 0 0-2-2h-4a2 2 0 0 0-2 2v16"/></svg>
    </div>
    <h3 class="text-[22px] font-bold text-dark mb-6 leading-tight" data-ps="src/pages/financial-services.astro:offering-title-1">Asset Management Services</h3>
    <p class="text-slate-600 text-[15px] leading-[1.5] mb-8 flex-grow" data-ps="src/pages/financial-services.astro:offering-body-1">
    Optimized portfolio construction across diverse asset classes. Strategic capital allocation for consistent, long-term returns.
    </p>
    <div class="mt-auto pt-6 border-t border-slate-100" data-ps="src/pages/financial-services.astro:offering-footer-1">
    <a href="https://spvhamc.com/" target="_blank" rel="noopener noreferrer" class="text-primary font-bold text-sm flex items-center gap-1 group/link transition-colors" data-ps="src/pages/financial-services.astro:offering-cta-1">
    Learn More <span class="inline-block transition-transform group-hover/link:translate-x-1" data-ps="src/pages/financial-services.astro:nhai6p">→</span>
    </a>
    </div>
    </div>

    <!-- Card 2 -->
    <div class="bg-white border border-border hover:border-secondary/40 p-10 rounded-2xl overflow-hidden shadow-[0_10px_40px_rgba(0,0,0,0.06)] flex flex-col h-full hover:translate-y-[-4px] transition-transform duration-300" data-ps="src/pages/financial-services.astro:offering-card-2">
    <div class="text-primary mb-6" data-ps="src/pages/financial-services.astro:offering-icon-2">
    <svg xmlns="http://www.w3.org/2000/svg" width="32" height="32" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="lucide lucide-landmark"><line x1="3" x2="21" y1="22" y2="22"/><line x1="6" x2="6" y1="18" y2="11"/><line x1="10" x2="10" y1="18" y2="11"/><line x1="14" x2="14" y1="18" y2="11"/><line x1="18" x2="18" y1="18" y2="11"/><polygon points="12 2 20 7 4 7"/></svg>
    </div>
    <h3 class="text-[22px] font-bold text-dark mb-6 leading-tight" data-ps="src/pages/financial-services.astro:offering-title-2">Private Wealth & Family Offices</h3>
    <p class="text-slate-600 text-[15px] leading-[1.5] mb-8 flex-grow" data-ps="src/pages/financial-services.astro:offering-body-2">
    Customized wealth planning and comprehensive financial advice. Multi-generational wealth preservation strategies for high-net-worth clients.
    </p>
    <div class="mt-auto pt-6 border-t border-slate-100" data-ps="src/pages/financial-services.astro:offering-footer-2">
    <a href="https://spvhamc.com/" target="_blank" rel="noopener noreferrer" class="text-primary font-bold text-sm flex items-center gap-1 group/link transition-colors" data-ps="src/pages/financial-services.astro:offering-cta-2">
    Learn More <span class="inline-block transition-transform group-hover/link:translate-x-1" data-ps="src/pages/financial-services.astro:nhai6q">→</span>
    </a>
    </div>
    </div>

    <!-- Card 3 -->
    <div class="bg-white border border-border hover:border-secondary/40 p-10 rounded-2xl overflow-hidden shadow-[0_10px_40px_rgba(0,0,0,0.06)] flex flex-col h-full hover:translate-y-[-4px] transition-transform duration-300" data-ps="src/pages/financial-services.astro:offering-card-3">
    <div class="text-primary mb-6" data-ps="src/pages/financial-services.astro:offering-icon-3">
    <svg xmlns="http://www.w3.org/2000/svg" width="32" height="32" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="lucide lucide-trending-up"><polyline points="22 7 13.5 15.5 8.5 10.5 2 17"/><polyline points="16 7 22 7 22 13"/></svg>
    </div>
    <h3 class="text-[22px] font-bold text-dark mb-6 leading-tight" data-ps="src/pages/financial-services.astro:offering-title-3">Investment Banking & Consulting</h3>
    <p class="text-slate-600 text-[15px] leading-[1.5] mb-8 flex-grow" data-ps="src/pages/financial-services.astro:offering-body-3">
    Expert advisory on mergers, acquisitions, and capital raising. Strategic corporate finance consulting for scalable business growth.
    </p>
    <div class="mt-auto pt-6 border-t border-slate-100" data-ps="src/pages/financial-services.astro:offering-footer-3">
    <a href="https://bpaconsulting.in/" target="_blank" rel="noopener noreferrer" class="text-primary font-bold text-sm flex items-center gap-1 group/link transition-colors" data-ps="src/pages/financial-services.astro:offering-cta-3">
    Learn More <span class="inline-block transition-transform group-hover/link:translate-x-1" data-ps="src/pages/financial-services.astro:nhai6r">→</span>
    </a>
    </div>
    </div>

    <!-- Card 4 -->
    <div class="bg-white border border-border hover:border-secondary/40 p-10 rounded-2xl overflow-hidden shadow-[0_10px_40px_rgba(0,0,0,0.06)] flex flex-col h-full hover:translate-y-[-4px] transition-transform duration-300" data-ps="src/pages/financial-services.astro:offering-card-4">
    <div class="text-primary mb-6" data-ps="src/pages/financial-services.astro:offering-icon-4">
    <svg xmlns="http://www.w3.org/2000/svg" width="32" height="32" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="lucide lucide-search"><circle cx="11" cy="11" r="8"/><path d="m21 21-4.3-4.3"/></svg>
    </div>
    <h3 class="text-[22px] font-bold text-dark mb-6 leading-tight" data-ps="src/pages/financial-services.astro:offering-title-4">Investment Advisory & Research</h3>
    <p class="text-slate-600 text-[15px] leading-[1.5] mb-8 flex-grow" data-ps="src/pages/financial-services.astro:offering-body-4">
    Data-driven market analysis and actionable investment insights. Proprietary research to identify optimal investment opportunities.
    </p>
    <div class="mt-auto pt-6 border-t border-slate-100" data-ps="src/pages/financial-services.astro:offering-footer-4">
    <a href="https://bpaconsulting.in/" target="_blank" rel="noopener noreferrer" class="text-primary font-bold text-sm flex items-center gap-1 group/link transition-colors" data-ps="src/pages/financial-services.astro:offering-cta-4">
    Learn More <span class="inline-block transition-transform group-hover/link:translate-x-1" data-ps="src/pages/financial-services.astro:nhai6s">→</span>
    </a>
    </div>
    </div>
    </div>
    </div>
    </section>

    <!-- Section: High-Impact CTA Banner -->
    <section class="relative py-[100px] bg-dark overflow-hidden text-center" data-ps="src/pages/financial-services.astro:cta-section">
      <!-- Background Pattern -->
      <div class="absolute inset-0 z-0 pointer-events-none" data-ps="src/pages/financial-services.astro:cta-texture">
        <img 
          src="/images/SPVH-Patterns-2-1536.webp" 
          alt="SPVH Brand Pattern" 
          class="w-full h-full object-cover opacity-10" data-ps="src/pages/financial-services.astro:153l89" />
        <div class="absolute inset-0 bg-gradient-to-b from-dark via-transparent to-dark" data-ps="src/pages/financial-services.astro:sq5df0"></div>
      </div>
      
      <div class="container mx-auto px-6 relative z-10" data-ps="src/pages/financial-services.astro:cta-container">
        <span class="block text-secondary text-sm font-bold uppercase tracking-[0.3em] mb-4" data-ps="src/pages/financial-services.astro:cta-kicker">START YOUR JOURNEY</span>
        
        <h2 class="text-4xl md:text-5xl lg:text-6xl font-bold mb-6" data-ps="src/pages/financial-services.astro:cta-h2">
          <span class="text-white" data-ps="src/pages/financial-services.astro:nhai6o">Ready to Build</span> 
          <span class="text-secondary" data-ps="src/pages/financial-services.astro:nhai6p">Wealth That Lasts Generations?</span>
        </h2>
        
        <p class="text-dark-muted text-lg md:text-xl max-w-2xl mx-auto mb-10" data-ps="src/pages/financial-services.astro:cta-subheadline">Explore more about our financial services to unlock your value and investments.</p>
        
        <div class="flex flex-col sm:flex-row items-center justify-center gap-5 mb-12" data-ps="src/pages/financial-services.astro:cta-buttons">
          <button data-modal-trigger="contact" class="flex items-center gap-2 px-10 py-4 bg-primary text-white font-bold rounded-full hover:bg-primary-hover transition-colors shadow-lg cursor-pointer" data-ps="src/pages/financial-services.astro:cta-primary">
            <svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="lucide lucide-phone"><path d="M22 16.92v3a2 2 0 0 1-2.18 2 19.79 19.79 0 0 1-8.63-3.07 19.5 19.5 0 0 1-6-6 19.79 19.79 0 0 1-3.07-8.67A2 2 0 0 1 4.11 2h3a2 2 0 0 1 2 1.72 12.84 12.84 0 0 0 .7 2.81 2 2 0 0 1-.45 2.11L8.09 9.91a16 16 0 0 0 6 6l1.27-1.27a2 2 0 0 1 2.11-.45 12.84 12.84 0 0 0 2.81.7A2 2 0 0 1 22 16.92z"/></svg>
            Speak to an expert
          </button>
          <a href="https://wa.me/919167466053?text=Hello!" target="_blank" rel="noopener noreferrer" class="flex items-center gap-2 px-10 py-4 bg-secondary text-white font-bold rounded-full hover:bg-secondary-hover transition-colors shadow-lg" data-ps="src/pages/financial-services.astro:cta-whatsapp">
            <svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="currentColor"><path d="M17.472 14.382c-.297-.149-1.758-.867-2.03-.967-.273-.099-.471-.148-.67.15-.197.297-.767.966-.94 1.164-.173.199-.347.223-.644.075-.297-.15-1.255-.463-2.39-1.475-.883-.788-1.48-1.761-1.653-2.059-.173-.297-.018-.458.13-.606.134-.133.298-.347.446-.52.149-.174.198-.298.298-.497.099-.198.05-.371-.025-.52-.075-.149-.669-1.612-.916-2.207-.242-.579-.487-.5-.669-.51-.173-.008-.371-.01-.57-.01-.198 0-.52.074-.792.372-.272.297-1.04 1.016-1.04 2.479 0 1.462 1.065 2.875 1.213 3.074.149.198 2.096 3.2 5.077 4.487.709.306 1.262.489 1.694.625.712.227 1.36.195 1.871.118.571-.085 1.758-.719 2.006-1.413.248-.694.248-1.289.173-1.413-.074-.124-.272-.198-.57-.347m-5.421 7.403h-.004a9.87 9.87 0 01-5.031-1.378l-.361-.214-3.741.982.998-3.648-.235-.374a9.86 9.86 0 01-1.51-5.26c.001-5.45 4.436-9.884 9.888-9.884 2.64 0 5.122 1.03 6.988 2.898a9.825 9.825 0 012.893 6.994c-.003 5.45-4.437 9.884-9.885 9.884m8.413-18.297A11.815 11.815 0 0012.05 0C5.495 0 .16 5.335.157 11.892c0 2.096.547 4.142 1.588 5.945L.057 24l6.305-1.654a11.882 11.882 0 005.683 1.448h.005c6.554 0 11.89-5.335 11.893-11.893a11.821 11.821 0 00-3.48-8.413z"/></svg>
            Chat with us
          </a>
        </div>
        
        <div class="flex flex-wrap items-center justify-center gap-x-8 gap-y-4 text-[14px] text-dark-muted" data-ps="src/pages/financial-services.astro:cta-trust">
          <div class="flex items-center gap-2" data-ps="src/pages/financial-services.astro:trust-1">
            <svg xmlns="http://www.w3.org/2000/svg" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="3" stroke-linecap="round" stroke-linejoin="round" class="text-secondary"><polyline points="20 6 9 17 4 12"/></svg>
            <span data-ps="src/pages/financial-services.astro:nhai6q">SEBI Registered</span>
          </div>
<div class="flex items-center gap-2" data-ps="src/pages/financial-services.astro:trust-3">
            <svg xmlns="http://www.w3.org/2000/svg" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="3" stroke-linecap="round" stroke-linejoin="round" class="text-secondary"><polyline points="20 6 9 17 4 12"/></svg>
            <span data-ps="src/pages/financial-services.astro:nhai6s">Response Within 24 Hours</span>
          </div>
        </div>
      </div>
    </section>

  </main>
</BaseLayout>
