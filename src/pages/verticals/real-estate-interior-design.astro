---
import BaseLayout from '@/layouts/BaseLayout.astro';
import VerticalNav from '@/components/VerticalNav.astro';
import { SITE } from '@/config/site';

const jsonLd = {
  "@context": "https://schema.org",
  "@type": "WebPage",
  "name": "Real Estate & Interior Design | SPVH Group",
  "description": "Bespoke Real Estate and Interior Design solutions for commercial infrastructure, luxury hospitality, and corporate environments.",
  "url": `${SITE.url}verticals/real-estate-interior-design`
};
---

<BaseLayout title="Real Estate & Interior Design | SPVH Group" description="Architecting Excellence in Real Estate and Interior Design." jsonLd={jsonLd}>
  <!-- Hero Section -->
  <section class="relative min-h-[90vh] flex items-center pt-20 overflow-hidden bg-dark" data-ps="src/pages/verticals/real-estate-interior-design.astro:hm2wr3">
    <div class="absolute inset-0 z-0" data-ps="src/pages/verticals/real-estate-interior-design.astro:s0yudy">
      <img 
        src="https://images.unsplash.com/photo-1582407947304-fd86f028f716?crop=entropy&cs=tinysrgb&fit=max&fm=jpg&ixid=M3w4MTQzNzh8MHwxfHNlYXJjaHwxfHxyZWFsJTIwZXN0YXRlfGVufDB8fHx8MTc3NTgxODkzN3ww&ixlib=rb-4.1.0&q=80&w=1200&auto=format"
        sizes="100vw"
        alt="Modern luxury architectural interior" 
        class="w-full h-full object-cover opacity-60"
        loading="eager"
        fetchpriority="high" data-ps="src/pages/verticals/real-estate-interior-design.astro:uj7yq4" crossorigin="anonymous" />
      <div class="absolute inset-0 bg-gradient-to-r from-dark via-dark/40 to-transparent" data-ps="src/pages/verticals/real-estate-interior-design.astro:s0yudx"></div>
    </div>

    <div class="container mx-auto px-6 relative z-10" data-ps="src/pages/verticals/real-estate-interior-design.astro:s0yudw">
      <div class="max-w-3xl hero-animate" data-ps="src/pages/verticals/real-estate-interior-design.astro:s0yudv">
        <a href="/#businesses" class="inline-block px-4 py-1 rounded-full bg-primary/20 backdrop-blur-md border border-primary/30 text-white text-sm font-bold uppercase tracking-widest mb-6 hover:bg-primary/40 transition-colors cursor-pointer" data-ps="src/pages/verticals/real-estate-interior-design.astro:s0yudu">Business Vertical</a>
        <h1 class="text-5xl md:text-7xl font-bold text-white mb-8 leading-[1.1]" data-ps="src/pages/verticals/real-estate-interior-design.astro:w84rax">
          <span class="text-primary uppercase flex flex-col justify-end min-h-[2.2em]" data-ps="src/pages/verticals/real-estate-interior-design.astro:w019m3">
            <span data-ps="src/pages/verticals/real-estate-interior-design.astro:w019m2">REAL ESTATE &</span>
            <span data-ps="src/pages/verticals/real-estate-interior-design.astro:w019m3">INTERIOR DESIGN</span>
          </span>
          <span class="block mt-4 text-2xl md:text-3xl font-normal text-dark-muted" data-ps="src/pages/verticals/real-estate-interior-design.astro:w019m3">Architecting Excellence.</span>
        </h1>
        <div class="bg-white/10 backdrop-blur-xl border border-white/20 p-8 rounded-2xl shadow-2xl" data-ps="src/pages/verticals/real-estate-interior-design.astro:s0yudt">
          <p class="text-xl text-dark-muted leading-relaxed" data-ps="src/pages/verticals/real-estate-interior-design.astro:6lmx5h">SPVH Group brings an institutional lens to real estate combining rigorous financial structuring with world-class design sensibility to deliver assets that perform and spaces that endure. From land monetization and development financing to luxury turnkey interiors, we partner with landowners, developers, investors, and UHNI clients at every stage of the real estate lifecycle.</p>
        </div>
      </div>
    </div>
  </section>

  <VerticalNav activePath="/verticals/real-estate-interior-design" />

  <!-- Section: Intro Text -->
  <section class="relative pt-20 pb-16 bg-surface overflow-hidden" data-ps="src/pages/verticals/real-estate-interior-design.astro:intro-text-section">
    <!-- Background Art / Pattern -->
    <div class="absolute inset-0 z-0 pointer-events-none" data-ps="src/pages/verticals/real-estate-interior-design.astro:intro-bg-art">
      <img 
        src="https://pagesmith-cdn.com/347b1a00/images/SPVH-Patterns-2-1536.webp" 
        alt="Geometric pattern background" 
        class="w-full h-full object-cover opacity-10" data-ps="src/pages/verticals/real-estate-interior-design.astro:153l89" />
      <div class="absolute inset-0 bg-gradient-to-b from-surface via-transparent to-surface" data-ps="src/pages/verticals/real-estate-interior-design.astro:sq5df0"></div>
    </div>
    
    <div class="container mx-auto px-6 max-w-[1400px] text-center relative z-10" data-ps="src/pages/verticals/real-estate-interior-design.astro:intro-container">
      <h2 class="text-3xl md:text-4xl font-bold text-[#496bad] mb-6" data-ps="src/pages/verticals/real-estate-interior-design.astro:intro-heading">
        Architecting Premium Spatial Assets
      </h2>
      <div class="max-w-6xl mx-auto" data-ps="src/pages/verticals/real-estate-interior-design.astro:intro-quote-container">
        <p class="text-lg md:text-[22px] text-[#00A896] leading-[1.6] font-medium italic" data-ps="src/pages/verticals/real-estate-interior-design.astro:intro-body">"At SPVH Group, our Real Estate & Interior Design division is central to our investment portfolio. We acquire, develop, and custom-design ultra-luxury homes and commercial spaces. By combining rigorous financial planning with visionary design, we use high-end real estate to safely protect and grow our clients' wealth."</p>
      </div>
    </div>
  </section>

  <!-- Section: Our Philosophy -->
  <section class="py-24 bg-[#0A1931] overflow-hidden" data-ps="src/pages/verticals/real-estate-interior-design.astro:philosophy-section-redesign">
    <div class="container px-6 mx-auto max-w-[1400px]" data-ps="src/pages/verticals/real-estate-interior-design.astro:philosophy-container">
      <div class="text-center max-w-4xl mx-auto mb-20" data-ps="src/pages/verticals/real-estate-interior-design.astro:philosophy-header">
        <span class="block text-[#00A896] text-sm font-bold uppercase tracking-[0.2em] mb-4" data-ps="src/pages/verticals/real-estate-interior-design.astro:philosophy-overline">OUR PHILOSOPHY</span>
        <h2 class="text-4xl md:text-5xl font-bold text-white leading-tight" data-ps="src/pages/verticals/real-estate-interior-design.astro:philosophy-tagline">
          Real Estate is Capital. Design is the Multiplier.
        </h2>
      </div>

      <div class="grid grid-cols-1 md:grid-cols-3 gap-8 max-w-[1050px] mx-auto" data-ps="src/pages/verticals/real-estate-interior-design.astro:philosophy-grid">
        <!-- Card 1 -->
        <div class="bg-[#14223a] border border-[#496bad] p-[30px] rounded-[12px] flex flex-col h-full text-center" data-ps="src/pages/verticals/real-estate-interior-design.astro:phil-card-1">
          <div class="h-[70px] flex items-center justify-center mb-6" data-ps="src/pages/verticals/real-estate-interior-design.astro:phil-icon-1">
            <h3 class="text-[22px] font-bold text-[#00A896]" data-ps="src/pages/verticals/real-estate-interior-design.astro:phil-title-1">Capital Discipline at Every Stage</h3>
          </div>
          <div class="h-[120px] flex items-start justify-center" data-ps="src/pages/verticals/real-estate-interior-design.astro:phil-body-1-container">
            <p class="text-[#D1D1D1] leading-[1.5] font-normal" data-ps="src/pages/verticals/real-estate-interior-design.astro:phil-body-1">
              Every real estate engagement begins with financial rigor viability analysis, costing assessment, and return modelling before a single design decision is made. We ensure that aesthetics and economics work in unison, not in tension.
            </p>
          </div>
        </div>

        <!-- Card 2 -->
        <div class="bg-[#14223a] border border-[#496bad] p-[30px] rounded-[12px] flex flex-col h-full text-center" data-ps="src/pages/verticals/real-estate-interior-design.astro:phil-card-2">
          <div class="h-[70px] flex items-center justify-center mb-6" data-ps="src/pages/verticals/real-estate-interior-design.astro:phil-icon-2">
            <h3 class="text-[22px] font-bold text-[#00A896]" data-ps="src/pages/verticals/real-estate-interior-design.astro:phil-title-2">Design as a Value Multiplier</h3>
          </div>
          <div class="h-[120px] flex items-start justify-center" data-ps="src/pages/verticals/real-estate-interior-design.astro:phil-body-2-container">
            <p class="text-[#D1D1D1] leading-[1.5] font-normal" data-ps="src/pages/verticals/real-estate-interior-design.astro:phil-body-2">
              Premium design is not a cost it is a yield driver. We apply sophisticated design thinking, international aesthetic standards, and material excellence to assets that demand a premium, and receive it.
            </p>
          </div>
        </div>

        <!-- Card 3 -->
        <div class="bg-[#14223a] border border-[#496bad] p-[30px] rounded-[12px] flex flex-col h-full text-center" data-ps="src/pages/verticals/real-estate-interior-design.astro:phil-card-3">
          <div class="h-[70px] flex items-center justify-center mb-6" data-ps="src/pages/verticals/real-estate-interior-design.astro:phil-icon-3">
            <h3 class="text-[22px] font-bold text-[#00A896]" data-ps="src/pages/verticals/real-estate-interior-design.astro:phil-title-3">End-to-End Partnership</h3>
          </div>
          <div class="h-[120px] flex items-start justify-center" data-ps="src/pages/verticals/real-estate-interior-design.astro:phil-body-3-container">
            <p class="text-[#D1D1D1] leading-[1.5] font-normal" data-ps="src/pages/verticals/real-estate-interior-design.astro:phil-body-3">
              From land identification and JV structuring to development monitoring and interior delivery, we remain engaged across the full project lifecycle. Our clients do not manage complexity we do.
            </p>
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- Section: Real Estate Services -->
  <section class="py-24 bg-surface" data-ps="src/pages/verticals/real-estate-interior-design.astro:services-section">
    <div class="container px-6 mx-auto max-w-[1400px]" data-ps="src/pages/verticals/real-estate-interior-design.astro:services-container">
      <div class="text-center mb-16" data-ps="src/pages/verticals/real-estate-interior-design.astro:services-header">
        <p class="text-[#00A896] font-bold text-sm uppercase tracking-[0.2em] mb-4" data-ps="src/pages/verticals/real-estate-interior-design.astro:services-overline">REAL ESTATE SERVICES</p>
        <h2 class="text-3xl md:text-4xl lg:text-5xl font-bold text-dark" data-ps="src/pages/verticals/real-estate-interior-design.astro:services-tagline">Institutional Advisory Across Every Real Estate Category</h2>
      </div>

      <div class="grid grid-cols-1 md:grid-cols-3 gap-8" data-ps="src/pages/verticals/real-estate-interior-design.astro:services-grid">
        <!-- Category 1: Commercial -->
        <div class="p-10 rounded-2xl border-2 border-primary/20 bg-white shadow-sm flex flex-col text-left transition-all duration-300" data-ps="src/pages/verticals/real-estate-interior-design.astro:service-card-1">
          <h3 class="text-[#00A896] text-2xl font-bold mb-6" data-ps="src/pages/verticals/real-estate-interior-design.astro:service-title-1">Commercial Real Estate Services</h3>
          <p class="text-dark text-base leading-[1.6] mb-8" data-ps="src/pages/verticals/real-estate-interior-design.astro:service-desc-1">We advise developers, investors, and corporates on commercial real estate across office, retail, and mixed-use categories. Our engagement spans the full project lifecycle — from early-stage viability through to development monitoring and asset exit.</p>
          
          <div class="mt-auto" data-ps="src/pages/verticals/real-estate-interior-design.astro:service-list-wrapper-1">
            <p class="text-[#00A896] font-bold text-sm uppercase tracking-wider mb-4" data-ps="src/pages/verticals/real-estate-interior-design.astro:service-list-header-1">Core Services Include:</p>
            <ul class="space-y-4 text-dark text-sm md:text-base leading-[1.6]" data-ps="src/pages/verticals/real-estate-interior-design.astro:service-list-1">
              <li data-ps="src/pages/verticals/real-estate-interior-design.astro:service-li-1-1"><strong class="font-bold">Viability & Costing Assessment:</strong> Detailed financial modelling, cost benchmarking, and return analysis to establish project feasibility before commitment.</li>
              <li data-ps="src/pages/verticals/real-estate-interior-design.astro:service-li-1-2"><strong class="font-bold">Development Financing:</strong> Structuring and sourcing of project finance, construction loans, and equity capital for commercial developments.</li>
              <li data-ps="src/pages/verticals/real-estate-interior-design.astro:service-li-1-3"><strong class="font-bold">JV Partner Identification:</strong> Matching landowners and developers with the right equity and operational partners, with structured JV frameworks that protect all stakeholders.</li>
              <li data-ps="src/pages/verticals/real-estate-interior-design.astro:service-li-1-4"><strong class="font-bold">Development Monitoring:</strong> On-ground oversight and milestone-linked progress monitoring to ensure delivery quality, timeline adherence, and cost discipline.</li>
              <li data-ps="src/pages/verticals/real-estate-interior-design.astro:service-li-1-5"><strong class="font-bold">Asset Leasing & Disposition:</strong> Strategic positioning, leasing advisory, and asset sale execution for commercial properties at optimal pricing and terms.</li>
            </ul>
          </div>
        </div>

        <!-- Category 2: Land -->
        <div class="p-10 rounded-2xl border-2 border-primary/20 bg-white shadow-sm flex flex-col text-left transition-all duration-300" data-ps="src/pages/verticals/real-estate-interior-design.astro:service-card-2">
          <h3 class="text-[#00A896] text-2xl font-bold mb-6" data-ps="src/pages/verticals/real-estate-interior-design.astro:service-title-2">Land Services</h3>
          <p class="text-dark text-base leading-[1.6] mb-8" data-ps="src/pages/verticals/real-estate-interior-design.astro:service-desc-2">Land is the foundation of all real estate value. We work with landowners, family estates, corporates, and institutional holders to unlock maximum value from land assets — through sale, development partnership, or structured monetisation.</p>
          
          <div class="mt-auto" data-ps="src/pages/verticals/real-estate-interior-design.astro:service-list-wrapper-2">
            <p class="text-[#00A896] font-bold text-sm uppercase tracking-wider mb-4" data-ps="src/pages/verticals/real-estate-interior-design.astro:service-list-header-2">Core Services Include:</p>
            <ul class="space-y-4 text-dark text-sm md:text-base leading-[1.6]" data-ps="src/pages/verticals/real-estate-interior-design.astro:service-list-2">
              <li data-ps="src/pages/verticals/real-estate-interior-design.astro:service-li-2-1"><strong class="font-bold">Land Viability Assessment:</strong> Zoning, FSI analysis, market comps, and highest-and-best-use evaluation.</li>
              <li data-ps="src/pages/verticals/real-estate-interior-design.astro:service-li-2-2"><strong class="font-bold">Land Monetisation Strategy:</strong> Identifying the optimal monetisation route — outright sale, JV development, or revenue share and executing with precision.</li>
              <li data-ps="src/pages/verticals/real-estate-interior-design.astro:service-li-2-3"><strong class="font-bold">JV Partner Structuring:</strong> Negotiating and structuring equitable joint development agreements that align landowner and developer interests.</li>
              <li data-ps="src/pages/verticals/real-estate-interior-design.astro:service-li-2-4"><strong class="font-bold">Development Financing for Land Projects:</strong> Advisory on construction and bridge finance solutions tailored to land-led development structures.</li>
              <li data-ps="src/pages/verticals/real-estate-interior-design.astro:service-li-2-5"><strong class="font-bold">Title & Due Diligence Coordination:</strong> Working alongside legal partners to ensure clean title, regulatory compliance, and transaction readiness.</li>
            </ul>
          </div>
        </div>

        <!-- Category 3: Residential -->
        <div class="p-10 rounded-2xl border-2 border-primary/20 bg-white shadow-sm flex flex-col text-left transition-all duration-300" data-ps="src/pages/verticals/real-estate-interior-design.astro:service-card-3">
          <h3 class="text-[#00A896] text-2xl font-bold mb-6" data-ps="src/pages/verticals/real-estate-interior-design.astro:service-title-3">Residential Services</h3>
          <p class="text-dark text-base leading-[1.6] mb-8" data-ps="src/pages/verticals/real-estate-interior-design.astro:service-desc-3">We serve UHNI clients, developers, and family offices seeking premium residential real estate advisory from acquisition strategy through to full delivery.</p>
          
          <div class="mt-auto" data-ps="src/pages/verticals/real-estate-interior-design.astro:service-list-wrapper-3">
            <p class="text-[#00A896] font-bold text-sm uppercase tracking-wider mb-4" data-ps="src/pages/verticals/real-estate-interior-design.astro:service-list-header-3">Core Services Include:</p>
            <ul class="space-y-4 text-dark text-sm md:text-base leading-[1.6]" data-ps="src/pages/verticals/real-estate-interior-design.astro:service-list-3">
              <li data-ps="src/pages/verticals/real-estate-interior-design.astro:service-li-3-1"><strong class="font-bold">Viability & Market Assessment:</strong> Demand analysis, competitive positioning, and pricing strategy for residential projects.</li>
              <li data-ps="src/pages/verticals/real-estate-interior-design.astro:service-li-3-2"><strong class="font-bold">Costing & Budget Structuring:</strong> Detailed cost planning, value engineering, and budget management across project phases.</li>
              <li data-ps="src/pages/verticals/real-estate-interior-design.astro:service-li-3-3"><strong class="font-bold">Development Financing:</strong> Sourcing and structuring residential project finance from institutional and alternative lenders.</li>
              <li data-ps="src/pages/verticals/real-estate-interior-design.astro:service-li-3-4"><strong class="font-bold">JV Partner Identification:</strong> Connecting residential developers with capital partners and operator networks.</li>
              <li data-ps="src/pages/verticals/real-estate-interior-design.astro:service-li-3-5"><strong class="font-bold">Development Monitoring:</strong> Quality oversight, timeline management, and cost control throughout the construction lifecycle.</li>
              <li data-ps="src/pages/verticals/real-estate-interior-design.astro:service-li-3-6"><strong class="font-bold">UHNI Acquisition Advisory:</strong> Bespoke advisory for ultra-high-net-worth buyers seeking premium residential assets evaluated for both lifestyle fit and investment merit.</li>
            </ul>
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- Interior Design Services -->
  <section class="py-24 bg-[#FFFFFF] relative overflow-hidden" data-ps="src/pages/verticals/real-estate-interior-design.astro:interior-design-section">
    <!-- Subtle architectural pattern overlay -->
    <div class="absolute inset-0 z-0 pointer-events-none opacity-[0.03]" data-ps="src/pages/verticals/real-estate-interior-design.astro:pattern-overlay">
      <svg width="100%" height="100%" xmlns="http://www.w3.org/2000/svg">
        <defs>
          <pattern id="diagonal-pattern" width="40" height="40" patternUnits="userSpaceOnUse">
            <path d="M0 40 L40 0 M-10 10 L10 -10 M30 50 L50 30" stroke="#1b202d" stroke-width="1" fill="none" />
          </pattern>
        </defs>
        <rect width="100%" height="100%" fill="url(#diagonal-pattern)" />
      </svg>
    </div>

    <div class="container mx-auto px-6 max-w-[1400px] relative z-10" data-ps="src/pages/verticals/real-estate-interior-design.astro:s0yud7">
      <div class="text-center max-w-4xl mx-auto mb-16" data-ps="src/pages/verticals/real-estate-interior-design.astro:s0yud6">
        <p class="text-[#00A896] font-bold text-sm uppercase tracking-[0.2em] mb-4" data-ps="src/pages/verticals/real-estate-interior-design.astro:interior-overline">INTERIOR DESIGN</p>
        <h2 class="text-3xl md:text-4xl lg:text-5xl font-bold text-[#1b202d] mb-8" data-ps="src/pages/verticals/real-estate-interior-design.astro:o4kdgl">Spaces That Inspire. Interiors That Endure.</h2>
        <p class="text-[#1b202d] text-lg md:text-xl leading-[1.6] italic max-w-[900px] mx-auto" data-ps="src/pages/verticals/real-estate-interior-design.astro:6lmx5g">"Our interior design practice operates at the intersection of design intelligence and execution excellence. We do not merely fill rooms; we curate spatial narratives that enhance human experience and asset value."</p>
      </div>

      <div class="grid grid-cols-1 md:grid-cols-3 gap-8" data-ps="src/pages/verticals/real-estate-interior-design.astro:s0yud5">
        <!-- Card 1: Concept Development -->
        <div class="p-12 rounded-2xl bg-white border border-[#e1e7ef] shadow-sm flex flex-col text-left transition-all duration-300" data-ps="src/pages/verticals/real-estate-interior-design.astro:s0yud4">
          <div class="mb-8" data-ps="src/pages/verticals/real-estate-interior-design.astro:s0yud3">
            <svg xmlns="http://www.w3.org/2000/svg" width="40" height="40" viewBox="0 0 24 24" fill="none" stroke="#00A896" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><path d="M21 16V8a2 2 0 0 0-1-1.73l-7-4a2 2 0 0 0-2 0l-7 4A2 2 0 0 0 3 8v8a2 2 0 0 0 1 1.73l7 4a2 2 0 0 0 2 0l7-4A2 2 0 0 0 21 16z"/><polyline points="3.27 6.96 12 12.01 20.73 6.96"/><line x1="12" y1="22.08" x2="12" y2="12"/></svg>
          </div>
          <h3 class="text-[#00A896] text-2xl font-bold mb-6" data-ps="src/pages/verticals/real-estate-interior-design.astro:9g5g8x">Concept Development & 3D Renders</h3>
          <p class="text-[#1b202d] text-base leading-[1.6] mb-8" data-ps="src/pages/verticals/real-estate-interior-design.astro:6lmx5f">Before a single material is specified, the vision must be established with absolute clarity. We develop rich, immersive concept narratives and photorealistic 3D renders that allow clients to experience the space before construction begins. Our concepts are rooted in design thinking, spatial logic, and the client's individual aesthetic—never templated, always bespoke.</p>
          
          <div class="mt-auto" data-ps="src/pages/verticals/real-estate-interior-design.astro:deliv-wrapper-1">
            <p class="text-[#00A896] font-bold text-sm uppercase tracking-wider mb-4" data-ps="src/pages/verticals/real-estate-interior-design.astro:deliv-header-1">Deliverables:</p>
            <ul class="space-y-3 text-[#1b202d] text-sm md:text-base leading-[1.6]" data-ps="src/pages/verticals/real-estate-interior-design.astro:deliv-list-1">
              <li class="flex items-start gap-3" data-ps="src/pages/verticals/real-estate-interior-design.astro:li-1-1"><span class="mt-2 w-1.5 h-1.5 rounded-full bg-[#486aad] shrink-0" data-ps="src/pages/verticals/real-estate-interior-design.astro:2ehhpb"></span>Mood boards and concept narrative</li>
              <li class="flex items-start gap-3" data-ps="src/pages/verticals/real-estate-interior-design.astro:li-1-2"><span class="mt-2 w-1.5 h-1.5 rounded-full bg-[#486aad] shrink-0" data-ps="src/pages/verticals/real-estate-interior-design.astro:2ehhpa"></span>Space planning and layout optimisation</li>
              <li class="flex items-start gap-3" data-ps="src/pages/verticals/real-estate-interior-design.astro:li-1-3"><span class="mt-2 w-1.5 h-1.5 rounded-full bg-[#486aad] shrink-0" data-ps="src/pages/verticals/real-estate-interior-design.astro:2ehhp9"></span>Photorealistic 3D visualisations</li>
              <li class="flex items-start gap-3" data-ps="src/pages/verticals/real-estate-interior-design.astro:li-1-4"><span class="mt-2 w-1.5 h-1.5 rounded-full bg-[#486aad] shrink-0" data-ps="src/pages/verticals/real-estate-interior-design.astro:2ehhp8"></span>Material and finish palettes</li>
              <li class="flex items-start gap-3" data-ps="src/pages/verticals/real-estate-interior-design.astro:li-1-5"><span class="mt-2 w-1.5 h-1.5 rounded-full bg-[#486aad] shrink-0" data-ps="src/pages/verticals/real-estate-interior-design.astro:2ehhp7"></span>Design presentation for client approval</li>
            </ul>
          </div>
