---
import BaseLayout from '@/layouts/BaseLayout.astro';
import VerticalNav from '@/components/VerticalNav.astro';
import { SITE } from '@/config/site';

const title = "Technology & Research | SPVH Group";
const description = "SPVH Group is committed to driving societal advancement through cutting-edge technological solutions and fostering visionary startups.";

const jsonLd = {
  "@context": "https://schema.org",
  "@type": "WebPage",
  "name": title,
  "description": description,
  "url": `${SITE.url}verticals/technology-research/`,
  "publisher": {
    "@type": "Organization",
    "name": SITE.name,
    "logo": {
      "@type": "ImageObject",
      "url": `${SITE.url}logo.png`
    }
  }
};
---

<BaseLayout title={title} description={description} jsonLd={jsonLd}>
  <main data-ps="src/pages/verticals/technology-research.astro:42mums">
    {/* Section 1: Vertical Hero & Strategic Overview */}
    <section class="relative min-h-[90vh] max-h-[90vh] flex items-center pt-20 overflow-hidden bg-dark" data-ps="src/pages/verticals/technology-research.astro:1ho8mz">
      <div class="absolute inset-0 z-0" data-ps="src/pages/verticals/technology-research.astro:wjkz33">
        <img 
          src="https://images.unsplash.com/photo-1592659762303-90081d34b277?crop=entropy&cs=tinysrgb&fit=max&fm=jpg&ixid=M3w4MTQzNzh8MHwxfHNlYXJjaHw2fHxlbmdpbmVlcmluZ3xlbnwwfHx8fDE3NzU4MTg0MDV8MA&ixlib=rb-4.1.0&q=80&w=1200&auto=format"
          sizes="100vw"
          alt="Future-forward technology network background" 
          class="w-full h-full object-cover opacity-60"
          loading="eager"
          fetchpriority="high" data-ps="src/pages/verticals/technology-research.astro:u1burh" crossorigin="anonymous" />
        <div class="absolute inset-0 bg-gradient-to-r from-dark via-dark/40 to-transparent" data-ps="src/pages/verticals/technology-research.astro:wjkz34"></div>
      </div>

      <div class="container mx-auto px-6 relative z-10" data-ps="src/pages/verticals/technology-research.astro:wjkz35">
        <div class="max-w-3xl hero-animate" data-ps="src/pages/verticals/technology-research.astro:xbipdl">
          <a href="/#businesses" class="inline-block px-4 py-1 rounded-full bg-primary/20 backdrop-blur-md border border-primary/30 text-white text-sm font-bold uppercase tracking-widest mb-6 hover:bg-primary/40 transition-colors cursor-pointer" data-ps="src/pages/verticals/technology-research.astro:84xuvd">Business Vertical</a>
          <h1 class="text-5xl md:text-7xl font-bold text-white mb-8 leading-[1.1]" data-ps="src/pages/verticals/technology-research.astro:5eme0g">
            <span class="text-primary uppercase flex flex-col justify-end min-h-[2.2em]" data-ps="src/pages/verticals/technology-research.astro:84xuvc">
              <span data-ps="src/pages/verticals/technology-research.astro:84xuvd">TECHNOLOGY &</span>
              <span data-ps="src/pages/verticals/technology-research.astro:84xuvc">RESEARCH</span>
            </span>
            <span class="block mt-4 text-2xl md:text-3xl font-normal text-dark-muted" data-ps="src/pages/verticals/technology-research.astro:84xuvc">Engineering the Future.</span>
          </h1>
          <div class="bg-white/10 backdrop-blur-xl border border-white/20 p-8 rounded-2xl shadow-2xl" data-ps="src/pages/verticals/technology-research.astro:xbipdk">
            <p class="text-xl text-dark-muted leading-relaxed" data-ps="src/pages/verticals/technology-research.astro:9e4b3w">At SPVH Group, technology is not a tool it is a philosophy. We approach the digital frontier with the conviction that meaningful innovation must be commercially anchored, socially purposeful, and built to endure. Through a disciplined blend of applied research, AI-led thinking, and enterprise-grade software development, we identify and build technology that solves at scale transforming complex problems into structured, monetizable, and impactful solutions.</p>
          </div>
        </div>
      </div>
    </section>

    <VerticalNav activePath="/verticals/technology-research" />

    <!-- Section: Strategic Infrastructure & Innovation (Intro) -->
    <section class="relative pt-20 pb-16 bg-surface overflow-hidden" data-ps="src/pages/verticals/technology-research.astro:intro-section">
      <!-- Background Art / Pattern -->
      <div class="absolute inset-0 z-0 pointer-events-none" data-ps="src/pages/verticals/technology-research.astro:intro-bg-art">
        <img 
          src="https://pagesmith-cdn.com/347b1a00/images/SPVH-Patterns-2-1536.webp" 
          alt="Geometric pattern background" 
          class="w-full h-full object-cover opacity-10" data-ps="src/pages/verticals/technology-research.astro:bg-pattern-img" />
        <div class="absolute inset-0 bg-gradient-to-b from-surface via-transparent to-surface" data-ps="src/pages/verticals/technology-research.astro:bg-gradient"></div>
      </div>
      
      <div class="container mx-auto px-6 max-w-[900px] text-center relative z-10" data-ps="src/pages/verticals/technology-research.astro:intro-container">
        <h2 class="text-3xl md:text-4xl font-bold text-primary mb-6" data-ps="src/pages/verticals/technology-research.astro:literature-h2">
          Scaling Digital Infrastructure & Innovation
        </h2>
        <p class="text-lg md:text-[20px] text-secondary leading-[1.6] font-medium italic" data-ps="src/pages/verticals/technology-research.astro:literature-p1">
          "As the forward-looking incubator of the SPVH Group, our Technology & Research vertical is dedicated to identifying, funding, and scaling transformative digital assets. We operate at the convergence of advanced data analytics, emerging technologies, and enterprise software, treating technological innovation as a high-growth asset class."
        </p>
      </div>
    </section>

    <!-- Section: Our Philosophy -->
    <section class="py-24 bg-dark relative overflow-hidden" data-ps="src/pages/verticals/technology-research.astro:philosophy-section-v2">
      <div class="container px-6 mx-auto max-w-[1400px] relative z-10" data-ps="src/pages/verticals/technology-research.astro:philosophy-container-v2">
        <div class="text-center max-w-4xl mx-auto mb-20" data-ps="src/pages/verticals/technology-research.astro:philosophy-header-v2">
          <span class="block text-secondary text-sm font-bold uppercase tracking-[0.2em] mb-4" data-ps="src/pages/verticals/technology-research.astro:philosophy-overline">OUR PHILOSOPHY</span>
          <h2 class="text-4xl md:text-5xl font-bold text-white leading-tight" data-ps="src/pages/verticals/technology-research.astro:philosophy-tagline">
            Innovation as a Discipline. Impact as a Standard.
          </h2>
        </div>

        <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-4 gap-8" data-ps="src/pages/verticals/technology-research.astro:philosophy-grid-v2">
          <!-- Card 1 -->
          <div class="bg-dark/90 border border-primary p-[30px] rounded-2xl flex flex-col h-full text-center" data-ps="src/pages/verticals/technology-research.astro:phil-v2-card-1">
            <div class="min-h-[70px] flex items-center justify-center mb-6" data-ps="src/pages/verticals/technology-research.astro:phil-v2-icon-1">
              <h3 class="text-[22px] font-bold text-secondary" data-ps="src/pages/verticals/technology-research.astro:phil-v2-title-1">Innovation as the Core</h3>
            </div>
            <div class="min-h-[120px] flex items-start justify-center" data-ps="src/pages/verticals/technology-research.astro:phil-v2-body-1-container">
              <p class="text-dark-muted leading-[1.5] font-normal" data-ps="src/pages/verticals/technology-research.astro:phil-v2-body-1">
                We are not interested in technology for its own sake. Every solution we build, fund, or validate must introduce a measurable step-change in efficiency, access, or market structure. Innovation, to us, is a discipline, not a department.
              </p>
            </div>
          </div>

          <!-- Card 2 -->
          <div class="bg-dark/90 border border-primary p-[30px] rounded-2xl flex flex-col h-full text-center" data-ps="src/pages/verticals/technology-research.astro:phil-v2-card-2">
            <div class="min-h-[70px] flex items-center justify-center mb-6" data-ps="src/pages/verticals/technology-research.astro:phil-v2-icon-2">
              <h3 class="text-[22px] font-bold text-secondary" data-ps="src/pages/verticals/technology-research.astro:phil-v2-title-2">AI as an Enabler</h3>
            </div>
            <div class="min-h-[120px] flex items-start justify-center" data-ps="src/pages/verticals/technology-research.astro:phil-v2-body-2-container">
              <p class="text-dark-muted leading-[1.5] font-normal" data-ps="src/pages/verticals/technology-research.astro:phil-v2-body-2">
                Artificial Intelligence is the most powerful leverage available. We embed AI as a foundational layer enabling faster decision-making, predictive intelligence, and scalable automation across the solutions we develop and advise on.
              </p>
            </div>
          </div>

          <!-- Card 3 -->
          <div class="bg-dark/90 border border-primary p-[30px] rounded-2xl flex flex-col h-full text-center" data-ps="src/pages/verticals/technology-research.astro:phil-v2-card-3">
            <div class="min-h-[70px] flex items-center justify-center mb-6" data-ps="src/pages/verticals/technology-research.astro:phil-v2-icon-3">
              <h3 class="text-[22px] font-bold text-secondary" data-ps="src/pages/verticals/technology-research.astro:phil-v2-title-3">Impact-Led Solutions</h3>
            </div>
            <div class="min-h-[120px] flex items-start justify-center" data-ps="src/pages/verticals/technology-research.astro:phil-v2-body-3-container">
              <p class="text-dark-muted leading-[1.5] font-normal" data-ps="src/pages/verticals/technology-research.astro:phil-v2-body-3">
                We design with outcomes in mind. Whether solving for enterprise productivity, industry-wide inefficiency, or societal access gaps, every solution is evaluated against its real-world impact—economic, operational, and human.
              </p>
            </div>
          </div>

          <!-- Card 4 -->
          <div class="bg-dark/90 border border-primary p-[30px] rounded-2xl flex flex-col h-full text-center" data-ps="src/pages/verticals/technology-research.astro:phil-v2-card-4">
            <div class="min-h-[70px] flex items-center justify-center mb-6" data-ps="src/pages/verticals/technology-research.astro:phil-v2-icon-4">
              <h3 class="text-[22px] font-bold text-secondary" data-ps="src/pages/verticals/technology-research.astro:phil-v2-title-4">Economic Preservation</h3>
            </div>
            <div class="min-h-[120px] flex items-start justify-center" data-ps="src/pages/verticals/technology-research.astro:phil-v2-body-4-container">
              <p class="text-dark-muted leading-[1.5] font-normal" data-ps="src/pages/verticals/technology-research.astro:phil-v2-body-4">
                We believe well-structured technology compounds value. Our mandate includes protecting the economic moat of businesses through IP strategy, sustainable SaaS architectures, and solutions built to appreciate.
              </p>
            </div>
          </div>
        </div>
      </div>
    </section>

    <!-- Section: What We Offer -->
    <section class="py-24 bg-white relative overflow-hidden" data-ps="src/pages/verticals/technology-research.astro:what-we-offer-section">
      <!-- Background Art / Pattern Overlay -->
      <div class="absolute inset-0 z-0 pointer-events-none opacity-5" data-ps="src/pages/verticals/technology-research.astro:what-we-offer-bg-art">
        <img 
          src="https://pagesmith-cdn.com/347b1a00/images/SPVH-Patterns-1536.webp" 
          alt="" 
          class="w-full h-full object-cover" data-ps="src/pages/verticals/technology-research.astro:what-we-offer-pattern-img" />
      </div>

      <div class="container px-6 mx-auto max-w-[1400px] relative z-10" data-ps="src/pages/verticals/technology-research.astro:what-we-offer-container">
        <div class="text-center mb-16" data-ps="src/pages/verticals/technology-research.astro:what-we-offer-header">
          <span class="text-secondary uppercase font-bold text-sm tracking-[0.2em] mb-4 block" data-ps="src/pages/verticals/technology-research.astro:what-we-offer-overline">WHAT WE OFFER</span>
          <h2 class="text-3xl md:text-5xl font-bold text-[#1b202d]" data-ps="src/pages/verticals/technology-research.astro:what-we-offer-tagline">Three Core Service Lines. One Mandate: Build What Lasts.</h2>
        </div>

        <div class="grid grid-cols-1 lg:grid-cols-3 gap-8" data-ps="src/pages/verticals/technology-research.astro:what-we-offer-grid">
          <!-- Card 1 -->
          <div class="bg-white border border-slate-100 rounded-2xl p-12 flex flex-col text-left shadow-lg hover:shadow-xl transition-all duration-300 relative group/card" data-ps="src/pages/verticals/technology-research.astro:service-card-1">
            <!-- Small SPVH Logo top right -->
            <div class="absolute top-6 right-6 opacity-20" data-ps="src/pages/verticals/technology-research.astro:service-card-logo-1">
              <span class="text-[10px] font-bold tracking-tighter text-[#1b202d] uppercase" data-ps="src/pages/verticals/technology-research.astro:84xuve">SPVH / TECH</span>
            </div>

            <!-- Icon Wrapper -->
            <div class="mb-10 relative w-16 h-16 flex items-center justify-center" data-ps="src/pages/verticals/technology-research.astro:service-icon-wrapper-1">
              <div class="absolute inset-0 bg-cyan-100/50 rounded-xl rotate-6 group-hover/card:rotate-12 transition-transform duration-500" data-ps="src/pages/verticals/technology-research.astro:service-icon-accent-1"></div>
              <div class="relative z-10 text-secondary" data-ps="src/pages/verticals/technology-research.astro:service-icon-1">
                <svg xmlns="http://www.w3.org/2000/svg" width="32" height="32" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="text-[#1b202d]"><circle cx="12" cy="12" r="10"/><path d="m9 12 2 2 4-4"/></svg>
              </div>
            </div>

            <h3 class="text-2xl font-bold text-secondary mb-6" data-ps="src/pages/verticals/technology-research.astro:service-title-1">Concept Feasibility & Viability Study</h3>
            <p class="text-[#1b202d] leading-[1.6] mb-8" data-ps="src/pages/verticals/technology-research.astro:service-desc-1">Before capital is committed, clarity must be established. We conduct rigorous, end-to-end feasibility and viability assessments for technology concepts — spanning market validation, technical architecture review, competitive landscape mapping, regulatory considerations, and financial modelling. The output is a structured report that gives founders, investors, and boards the clarity to move forward — or pivot — with conviction.</p>
            
            <div class="mt-auto" data-ps="src/pages/verticals/technology-research.astro:service-list-wrapper-1">
              <p class="text-secondary font-bold text-sm mb-4" data-ps="src/pages/verticals/technology-research.astro:service-list-header-1">What's Included:</p>
              <ul class="space-y-3 text-[#1b202d]" data-ps="src/pages/verticals/technology-research.astro:service-list-1">
                <li class="flex items-start gap-3" data-ps="src/pages/verticals/technology-research.astro:service-li-1-1">
                  <span class="text-[#107CDE] mt-1" data-ps="src/pages/verticals/technology-research.astro:vvamuq">●</span> Market sizing and demand validation
                </li>
                <li class="flex items-start gap-3" data-ps="src/pages/verticals/technology-research.astro:service-li-1-2">
                  <span class="text-[#107CDE] mt-1" data-ps="src/pages/verticals/technology-research.astro:vvamur">●</span> Technical feasibility assessment
                </li>
                <li class="flex items-start gap-3" data-ps="src/pages/verticals/technology-research.astro:service-li-1-3">
                  <span class="text-[#107CDE] mt-1" data-ps="src/pages/verticals/technology-research.astro:vvamus">●</span> Competitive benchmarking
                </li>
                <li class="flex items-start gap-3" data-ps="src/pages/verticals/technology-research.astro:service-li-1-4">
                  <span class="text-[#107CDE] mt-1" data-ps="src/pages/verticals/technology-research.astro:vvamut">●</span> Go-to-market readiness review
                </li>
                <li class="flex items-start gap-3" data-ps="src/pages/verticals/technology-research.astro:service-li-1-5">
                  <span class="text-[#107CDE] mt-1" data-ps="src/pages/verticals/technology-research.astro:vvamuu">●</span> Financial viability modelling
                </li>
                <li class="flex items-start gap-3" data-ps="src/pages/verticals/technology-research.astro:service-li-1-6">
                  <span class="text-[#107CDE] mt-1" data-ps="src/pages/verticals/technology-research.astro:vvamuv">●</span> Structured executive report with recommendations
                </li>
              </ul>
            </div>
          </div>

          <!-- Card 2 -->
          <div class="bg-white border border-slate-100 rounded-2xl p-12 flex flex-col text-left shadow-lg hover:shadow-xl transition-all duration-300 relative group/card" data-ps="src/pages/verticals/technology-research.astro:service-card-2">
            <!-- Small SPVH Logo top right -->
            <div class="absolute top-6 right-6 opacity-20" data-ps="src/pages/verticals/technology-research.astro:service-card-logo-2">
              <span class="text-[10px] font-bold tracking-tighter text-[#1b202d] uppercase" data-ps="src/pages/verticals/technology-research.astro:84xuvd">SPVH / TECH</span>
            </div>

            <!-- Icon Wrapper -->
            <div class="mb-10 relative w-16 h-16 flex items-center justify-center" data-ps="src/pages/verticals/technology-research.astro:service-icon-wrapper-2">
              <div class="absolute inset-0 bg-cyan-100/50 rounded-xl rotate-6 group-hover/card:rotate-12 transition-transform duration-500" data-ps="src/pages/verticals/technology-research.astro:service-icon-accent-2"></div>
              <div class="relative z-10 text-secondary" data-ps="src/pages/verticals/technology-research.astro:service-icon-2">
                <svg xmlns="http://www.w3.org/2000/svg" width="32" height="32" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="text-[#1b202d]"><path d="M12 22s8-4 8-10V5l-8-3-8 3v7c0 6 8 10 8 10"/><path d="m9 12 2 2 4-4"/></svg>
              </div>
            </div>

            <h3 class="text-2xl font-bold text-secondary mb-6" data-ps="src/pages/verticals/technology-research.astro:service-title-2">Design & Development of SaaS Models</h3>
            <p class="text-[#1b202d] leading-[1.6] mb-8" data-ps="src/pages/verticals/technology-research.astro:service-desc-2">We partner with founders and enterprises to design and develop high-margin, scalable Software-as-a-Service platforms. Our engagement spans the full product lifecycle — from architectural design and UX strategy through to build, testing, and go-to-market structuring. We focus exclusively on SaaS architectures that generate recurring revenue, demonstrate network effects, and are structured to scale without proportional cost growth.</p>
            
            <div class="mt-auto" data-ps="src/pages/verticals/technology-research.astro:service-list-wrapper-2">
              <p class="text-secondary font-bold text-sm mb-4" data-ps="src/pages/verticals/technology-research.astro:service-list-header-2">What's Included:</p>
              <ul class="space-y-3 text-[#1b202d]" data-ps="src/pages/verticals/technology-research.astro:service-list-2">
                <li class="flex items-start gap-3" data-ps="src/pages/verticals/technology-research.astro:service-li-2-1">
                  <span class="text-[#107CDE] mt-1" data-ps="src/pages/verticals/technology-research.astro:vvamuw">●</span> Product architecture and system design
                </li>
                <li class="flex items-start gap-3" data-ps="src/pages/verticals/technology-research.astro:service-li-2-2">
                  <span class="text-[#107CDE] mt-1" data-ps="src/pages/verticals/technology-research.astro:vvamux">●</span> UI/UX strategy and design thinking
                </li>
                <li class="flex items-start gap-3" data-ps="src/pages/verticals/technology-research.astro:service-li-2-3">
                  <span class="text-[#107CDE] mt-1" data-ps="src/pages/verticals/technology-research.astro:84xuvl">●</span> Full-stack development and QA
                </li>
                <li class="flex items-start gap-3" data-ps="src/pages/verticals/technology-research.astro:service-li-2-4">
                  <span class="text-[#107CDE] mt-1" data-ps="src/pages/verticals/technology-research.astro:84xuvk">●</span> Subscription and monetisation model structuring
                </li>
                <li class="flex items-start gap-3" data-ps="src/pages/verticals/technology-research.astro:service-li-2-5">
                  <span class="text-[#107CDE] mt-1" data-ps="src/pages/verticals/technology-research.astro:84xuvj">●</span> Scalability and performance engineering
                </li>
                <li class="flex items-start gap-3" data-ps="src/pages/verticals/technology-research.astro:service-li-2-6">
                  <span class="text-[#107CDE] mt-1" data-ps="src/pages/verticals/technology-research.astro:84xuvi">●</span> GTM and launch readiness planning
                </li>
              </ul>
            </div>
          </div>

          <!-- Card 3 -->
          <div class="bg-white border border-slate-100 rounded-2xl p-12 flex flex-col text-left shadow-lg hover:shadow-xl transition-all duration-300 relative group/card" data-ps="src/pages/verticals/technology-research.astro:service-card-3">
            <!-- Small SPVH Logo top right -->
            <div class="absolute top-6 right-6 opacity-20" data-ps="src/pages/verticals/technology-research.astro:service-card-logo-3">
              <span class="text-[10px] font-bold tracking-tighter text-[#1b202d] uppercase" data-ps="src/pages/verticals/technology-research.astro:84xuvc">SPVH / TECH</span>
            </div>

            <!-- Icon Wrapper -->
            <div class="mb-10 relative w-16 h-16 flex items-center justify-center" data-ps="src/pages/verticals/technology-research.astro:service-icon-wrapper-3">
              <div class="absolute inset-0 bg-cyan-100/50 rounded-xl rotate-6 group-hover/card:rotate-12 transition-transform duration-500" data-ps="src/pages/verticals/technology-research.astro:service-icon-accent-3"></div>
              <div class="relative z-10 text-secondary" data-ps="src/pages/verticals/technology-research.astro:service-icon-3">
                <svg xmlns="http://www.w3.org/2000/svg" width="32" height="32" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="text-[#1b202d]"><path d="M12 22s8-4 8-10V5l-8-3-8 3v7c0 6 8 10 8 10"/><circle cx="12" cy="12" r="3"/></svg>
              </div>
            </div>

            <h3 class="text-2xl font-bold text-secondary mb-6" data-ps="src/pages/verticals/technology-research.astro:service-title-3">IP Monetisation & Outright Sale</h3>
            <p class="text-[#1b202d] leading-[1.6] mb-8" data-ps="src/pages/verticals/technology-research.astro:service-desc-3">Intellectual Property is one of the most underutilised assets on most balance sheets. We advise technology owners, startups, and enterprises on the strategic monetisation of their IP — whether through licensing frameworks, structured royalty models, or outright IP sale transactions. Our approach combines financial structuring with legal advisory coordination to ensure maximum value realisation from proprietary technology, patents, and digital assets.</p>
            
            <div class="mt-auto" data-ps="src/pages/verticals/technology-research.astro:service-list-wrapper-3">
              <p class="text-secondary font-bold text-sm mb-4" data-ps="src/pages/verticals/technology-research.astro:service-list-header-3">What's Included:</p>
              <ul class="space-y-3 text-[#1b202d]" data-ps="src/pages/verticals/technology-research.astro:service-list-3">
                <li class="flex items-start gap-3" data-ps="src/pages/verticals/technology-research.astro:service-li-3-1">
                  <span class="text-[#107CDE] mt-1" data-ps="src/pages/verticals/technology-research.astro:84xuvh">●</span> IP audit and valuation
                </li>
                <li class="flex items-start gap-3" data-ps="src/pages/verticals/technology-research.astro:service-li-3-2">
                  <span class="text-[#107CDE] mt-1" data-ps="src/pages/verticals/technology-research.astro:84xuvg">●</span> Licensing and royalty structure design
                </li>
                <li class="flex items-start gap-3" data-ps="src/pages/verticals/technology-research.astro:service-li-3-3">
                  <span class="text-[#107CDE] mt-1" data-ps="src/pages/verticals/technology-research.astro:84xuvf">●</span> Buyer identification and transaction management
                </li>
                <li class="flex items-start gap-3" data-ps="src/pages/verticals/technology-research.astro:service-li-3-4">
                  <span class="text-[#107CDE] mt-1" data-ps="src/pages/verticals/technology-research.astro:84xuve">●</span> Legal advisory coordination
                </li>
                <li class="flex items-start gap-3" data-ps="src/pages/verticals/technology-research.astro:service-li-3-5">
